<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_img">img</variable>
    <variable id="var_gray">gray</variable>
    <variable id="var_p0">p0</variable>
    <variable id="var_p1">p1</variable>
  </variables>
  <block type="cv_import" id="b0" x="30" y="30">
    <next>
      <block type="cv_load" id="b1">
        <field name="VAR" id="var_img">img</field>
        <field name="SAMPLE">gradient</field>
        <next>
          <block type="var_set" id="b2">
            <field name="VAR" id="var_gray">gray</field>
            <value name="VALUE">
              <block type="cv_to_gray" id="b3">
                <value name="IMG"><block type="val_var" id="bv1"><field name="VAR" id="var_img">img</field></block></value>
              </block>
            </value>
            <next>
              <block type="var_set" id="b4">
                <field name="VAR" id="var_p0">p0</field>
                <value name="VALUE">
                  <block type="cv_get_pixel" id="b5">
                    <value name="IMG"><block type="val_var" id="bv2"><field name="VAR" id="var_gray">gray</field></block></value>
                    <value name="X"><block type="val_number" id="n1"><field name="NUM">0</field></block></value>
                    <value name="Y"><block type="val_number" id="n2"><field name="NUM">0</field></block></value>
                  </block>
                </value>
                <next>
                  <block type="var_set" id="b6">
                    <field name="VAR" id="var_p1">p1</field>
                    <value name="VALUE">
                      <block type="cv_get_pixel" id="b7">
                        <value name="IMG"><block type="val_var" id="bv3"><field name="VAR" id="var_gray">gray</field></block></value>
                        <value name="X"><block type="val_number" id="n3"><field name="NUM">119</field></block></value>
                        <value name="Y"><block type="val_number" id="n4"><field name="NUM">119</field></block></value>
                      </block>
                    </value>
                    <next>
                      <block type="py_print" id="b8">
                        <value name="VALUE"><block type="val_var" id="bv4"><field name="VAR" id="var_p0">p0</field></block></value>
                        <next>
                          <block type="py_print" id="b9">
                            <value name="VALUE"><block type="val_var" id="bv5"><field name="VAR" id="var_p1">p1</field></block></value>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
