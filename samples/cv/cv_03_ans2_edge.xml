<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_img">img</variable>
    <variable id="var_blurred">blurred</variable>
    <variable id="var_e1">edge_raw</variable>
    <variable id="var_e2">edge_smooth</variable>
  </variables>
  <block type="cv_import" id="b0" x="30" y="30">
    <next>
      <block type="cv_load" id="b1">
        <field name="VAR" id="var_img">img</field>
        <field name="SAMPLE">checker</field>
        <next>
          <block type="var_set" id="b2">
            <field name="VAR" id="var_blurred">blurred</field>
            <value name="VALUE">
              <block type="cv_filter_blur" id="b3">
                <value name="IMG"><block type="val_var" id="bv1"><field name="VAR" id="var_img">img</field></block></value>
                <field name="SIZE">3</field>
              </block>
            </value>
            <next>
              <block type="var_set" id="b4">
                <field name="VAR" id="var_e1">edge_raw</field>
                <value name="VALUE">
                  <block type="cv_filter_edge" id="b5">
                    <value name="IMG"><block type="val_var" id="bv2"><field name="VAR" id="var_img">img</field></block></value>
                  </block>
                </value>
                <next>
                  <block type="var_set" id="b6">
                    <field name="VAR" id="var_e2">edge_smooth</field>
                    <value name="VALUE">
                      <block type="cv_filter_edge" id="b7">
                        <value name="IMG"><block type="val_var" id="bv3"><field name="VAR" id="var_blurred">blurred</field></block></value>
                      </block>
                    </value>
                    <next>
                      <block type="cv_show" id="b8">
                        <value name="IMG"><block type="val_var" id="bv4"><field name="VAR" id="var_e1">edge_raw</field></block></value>
                        <next>
                          <block type="cv_show" id="b9">
                            <value name="IMG"><block type="val_var" id="bv5"><field name="VAR" id="var_e2">edge_smooth</field></block></value>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
