<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vbx">ball_x</variable>
    <variable id="vby">ball_y</variable>
  </variables>
  <block type="game_init" x="20" y="20">
    <value name="W"><block type="val_number"><field name="NUM">640</field></block></value>
    <value name="H"><block type="val_number"><field name="NUM">400</field></block></value>
    <value name="TITLE"><block type="val_str"><field name="TEXT">アニメーション</field></block></value>
    <next>
      <block type="var_set">
        <field name="VAR" id="vbx">ball_x</field>
        <value name="VALUE"><block type="val_number"><field name="NUM">320</field></block></value>
        <next>
          <block type="var_set">
            <field name="VAR" id="vby">ball_y</field>
            <value name="VALUE"><block type="val_number"><field name="NUM">0</field></block></value>
            <next>
              <block type="game_loop">
                <statement name="DO">
                  <block type="game_events">
                    <next>
                      <block type="game_fill">
                        <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#000000</field></block></value>
                        <next>
                          <block type="game_draw_circle">
                            <value name="X"><block type="val_var"><field name="VAR" id="vbx">ball_x</field></block></value>
                            <value name="Y"><block type="val_var"><field name="VAR" id="vby">ball_y</field></block></value>
                            <value name="R"><block type="val_number"><field name="NUM">20</field></block></value>
                            <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#ff0000</field></block></value>
                            <next>
                              <block type="var_change">
                                <field name="VAR" id="vbx">ball_x</field>
                                <value name="AMOUNT"><block type="val_number"><field name="NUM">2</field></block></value>
                                <next>
                              <block type="var_change">
                                <field name="VAR" id="vby">ball_y</field>
                                <value name="AMOUNT"><block type="val_number"><field name="NUM">3</field></block></value>
                                <next>
                                  <block type="pico_if">
                                    <value name="IF0">
                                      <block type="cond_compare">
                                        <field name="OP">&gt;</field>
                                        <value name="LEFT"><block type="val_var"><field name="VAR" id="vbx">ball_x</field></block></value>
                                        <value name="RIGHT"><block type="val_number"><field name="NUM">640</field></block></value>
                                      </block>
                                    </value>
                                    <statement name="DO0">
                                      <block type="var_set">
                                        <field name="VAR" id="vbx">ball_x</field>
                                        <value name="VALUE"><block type="val_number"><field name="NUM">0</field></block></value>
                                      </block>
                                    </statement>
                                    <next>
                                  <block type="pico_if">
                                    <value name="IF0">
                                      <block type="cond_compare">
                                        <field name="OP">&gt;</field>
                                        <value name="LEFT"><block type="val_var"><field name="VAR" id="vby">ball_y</field></block></value>
                                        <value name="RIGHT"><block type="val_number"><field name="NUM">400</field></block></value>
                                      </block>
                                    </value>
                                    <statement name="DO0">
                                      <block type="var_set">
                                        <field name="VAR" id="vby">ball_y</field>
                                        <value name="VALUE"><block type="val_number"><field name="NUM">0</field></block></value>
                                      </block>
                                    </statement>
                                    <next>
                                      <block type="game_flip">
                                        <value name="FPS"><block type="val_number"><field name="NUM">60</field></block></value>
                                      </block>
                                    </next>
                                  </block>
                                    </next>
                                  </block>
                                </next>
                              </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </statement>
                <next>
                  <block type="game_quit"></block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
