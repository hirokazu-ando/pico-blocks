<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vby">bullet_y</variable>
  </variables>
  <block type="game_init" x="20" y="20">
    <value name="W"><block type="val_number"><field name="NUM">640</field></block></value>
    <value name="H"><block type="val_number"><field name="NUM">400</field></block></value>
    <value name="TITLE"><block type="val_str"><field name="TEXT">Bullet</field></block></value>
    <next>
      <block type="var_set">
        <field name="VAR" id="vby">bullet_y</field>
        <value name="VALUE"><block type="val_number"><field name="NUM">380</field></block></value>
        <next>
          <block type="game_loop">
            <statement name="DO">
              <block type="game_events">
                <next>
                  <block type="game_fill">
                    <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#0a0a2e</field></block></value>
                    <next>
                      <block type="var_change">
                        <field name="VAR" id="vby">bullet_y</field>
                        <value name="AMOUNT"><block type="val_number"><field name="NUM">-8</field></block></value>
                        <next>
                          <block type="pico_if">
                            <mutation elseif="0" else="0" />
                            <value name="IF0">
                              <block type="cond_compare">
                                <field name="OP">&lt;</field>
                                <value name="LEFT"><block type="val_var"><field name="VAR" id="vby">bullet_y</field></block></value>
                                <value name="RIGHT"><block type="val_number"><field name="NUM">0</field></block></value>
                              </block>
                            </value>
                            <statement name="DO0">
                              <block type="var_set">
                                <field name="VAR" id="vby">bullet_y</field>
                                <value name="VALUE"><block type="val_number"><field name="NUM">380</field></block></value>
                              </block>
                            </statement>
                            <next>
                              <block type="game_draw_image">
                                <value name="URL"><block type="game_image_preset"><field name="IMG">assets/game-icons/bullet.svg</field></block></value>
                                <value name="X"><block type="val_number"><field name="NUM">310</field></block></value>
                                <value name="Y"><block type="val_var"><field name="VAR" id="vby">bullet_y</field></block></value>
                                <value name="W"><block type="val_number"><field name="NUM">16</field></block></value>
                                <value name="H"><block type="val_number"><field name="NUM">16</field></block></value>
                                <next>
                                  <block type="game_draw_image">
                                    <value name="URL"><block type="game_image_preset"><field name="IMG">assets/game-icons/player_ship.svg</field></block></value>
                                    <value name="X"><block type="val_number"><field name="NUM">290</field></block></value>
                                    <value name="Y"><block type="val_number"><field name="NUM">340</field></block></value>
                                    <value name="W"><block type="val_number"><field name="NUM">48</field></block></value>
                                    <value name="H"><block type="val_number"><field name="NUM">48</field></block></value>
                                    <next>
                                      <block type="game_flip">
                                        <value name="FPS"><block type="val_number"><field name="NUM">60</field></block></value>
                                      </block>
                                    </next>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </statement>
            <next>
              <block type="game_quit" />
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
