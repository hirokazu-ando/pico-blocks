<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="g20c_px">px</variable>
    <variable id="g20c_ix">ix</variable>
    <variable id="g20c_iy">iy</variable>
    <variable id="g20c_itype">itype</variable>
    <variable id="g20c_score">score</variable>
    <variable id="g20c_mult">mult</variable>
    <variable id="g20c_mtimer">mtimer</variable>
    <variable id="g20c_running">running</variable>
  </variables>
  <block type="game_import_random" x="20" y="20">
    <next>
      <block type="game_init">
        <value name="W"><block type="val_number"><field name="NUM">640</field></block></value>
        <value name="H"><block type="val_number"><field name="NUM">400</field></block></value>
        <value name="TITLE"><block type="val_str"><field name="TEXT">Star Super</field></block></value>
        <next>
          <block type="var_set">
            <field name="VAR" id="g20c_px">px</field>
            <value name="VALUE"><block type="val_number"><field name="NUM">300</field></block></value>
            <next>
              <block type="var_set">
                <field name="VAR" id="g20c_ix">ix</field>
                <value name="VALUE"><block type="game_random_int"><field name="LO">0</field><field name="HI">600</field></block></value>
                <next>
                  <block type="var_set">
                    <field name="VAR" id="g20c_iy">iy</field>
                    <value name="VALUE"><block type="val_number"><field name="NUM">-40</field></block></value>
                    <next>
                      <block type="var_set">
                        <field name="VAR" id="g20c_itype">itype</field>
                        <value name="VALUE"><block type="val_str"><field name="TEXT">coin</field></block></value>
                        <next>
                          <block type="var_set">
                            <field name="VAR" id="g20c_score">score</field>
                            <value name="VALUE"><block type="val_number"><field name="NUM">0</field></block></value>
                            <next>
                              <block type="var_set">
                                <field name="VAR" id="g20c_mult">mult</field>
                                <value name="VALUE"><block type="val_number"><field name="NUM">1</field></block></value>
                                <next>
                                  <block type="var_set">
                                    <field name="VAR" id="g20c_mtimer">mtimer</field>
                                    <value name="VALUE"><block type="val_number"><field name="NUM">0</field></block></value>
                                    <next>
                                      <block type="var_set">
                                        <field name="VAR" id="g20c_running">running</field>
                                        <value name="VALUE"><block type="val_bool"><field name="BOOL">True</field></block></value>
                                        <next>
                                          <block type="game_loop">
                                            <statement name="DO">
                                              <block type="game_events">
                                                <next>
                                                  <block type="game_fill">
                                                    <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#0a0a2e</field></block></value>
                                                    <next>
                                                      <block type="pico_if">
                                                        <value name="IF0"><block type="game_key_pressed"><field name="KEY">K_RIGHT</field></block></value>
                                                        <statement name="DO0">
                                                          <block type="var_change">
                                                            <field name="VAR" id="g20c_px">px</field>
                                                            <value name="AMOUNT"><block type="val_number"><field name="NUM">4</field></block></value>
                                                          </block>
                                                        </statement>
                                                        <next>
                                                          <block type="pico_if">
                                                            <value name="IF0"><block type="game_key_pressed"><field name="KEY">K_LEFT</field></block></value>
                                                            <statement name="DO0">
                                                              <block type="var_change">
                                                                <field name="VAR" id="g20c_px">px</field>
                                                                <value name="AMOUNT"><block type="val_number"><field name="NUM">-4</field></block></value>
                                                              </block>
                                                            </statement>
                                                            <next>
                                                              <block type="var_change">
                                                                <field name="VAR" id="g20c_iy">iy</field>
                                                                <value name="AMOUNT"><block type="val_number"><field name="NUM">3</field></block></value>
                                                                <next>
                                                                  <block type="pico_if">
                                                                    <value name="IF0">
                                                                      <block type="cond_compare">
                                                                        <field name="OP">&gt;</field>
                                                                        <value name="LEFT"><block type="val_var"><field name="VAR" id="g20c_iy">iy</field></block></value>
                                                                        <value name="RIGHT"><block type="val_number"><field name="NUM">400</field></block></value>
                                                                      </block>
                                                                    </value>
                                                                    <statement name="DO0">
                                                                      <block type="var_set">
                                                                        <field name="VAR" id="g20c_iy">iy</field>
                                                                        <value name="VALUE"><block type="val_number"><field name="NUM">-40</field></block></value>
                                                                        <next>
                                                                          <block type="var_set">
                                                                            <field name="VAR" id="g20c_ix">ix</field>
                                                                            <value name="VALUE"><block type="game_random_int"><field name="LO">0</field><field name="HI">600</field></block></value>
                                                                            <next>
                                                                              <block type="pico_if">
                                                                                <mutation elseif="0" else="1" />
