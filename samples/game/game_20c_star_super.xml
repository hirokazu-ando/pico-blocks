                                                                                  <block type="cond_compare">
                                                                                    <field name="OP">==</field>
                                                                                    <value name="LEFT">
                                                                                      <block type="py_random_int">
                                                                                        <value name="FROM"><block type="val_number"><field name="NUM">1</field></block></value>
