                                                                                      </block>
                                                                                    </value>
                                                                                    <value name="RIGHT"><block type="val_number"><field name="NUM">1</field></block></value>
                                                                                  </block>
                                                                                </value>
                                                                                <statement name="DO0">
                                                                                  <block type="var_set">
                                                                                    <field name="VAR" id="g20c_itype">itype</field>
                                                                                    <value name="VALUE"><block type="val_str"><field name="TEXT">star</field></block></value>
                                                                                  </block>
                                                                                </statement>
                                                                                <statement name="ELSE">
                                                                                  <block type="var_set">
                                                                                    <field name="VAR" id="g20c_itype">itype</field>
                                                                                    <value name="VALUE"><block type="val_str"><field name="TEXT">coin</field></block></value>
                                                                                  </block>
                                                                                </statement>
                                                                              </block>
                                                                            </next>
                                                                          </block>
                                                                        </next>
                                                                      </block>
                                                                    </statement>
                                                                    <next>
                                                                      <block type="pico_if">
                                                                        <value name="IF0">
                                                                          <block type="cond_and">
                                                                            <value name="A">
                                                                              <block type="cond_compare">
                                                                                <field name="OP">&lt;</field>
                                                                                <value name="LEFT">
                                                                                  <block type="py_abs">
                                                                                    <value name="VALUE">
                                                                                      <block type="py_math_op">
                                                                                        <field name="OP">-</field>
                                                                                        <value name="LEFT"><block type="val_var"><field name="VAR" id="g20c_px">px</field></block></value>
                                                                                        <value name="RIGHT"><block type="val_var"><field name="VAR" id="g20c_ix">ix</field></block></value>
                                                                                      </block>
                                                                                    </value>
                                                                                  </block>
                                                                                </value>
                                                                                <value name="RIGHT"><block type="val_number"><field name="NUM">36</field></block></value>
                                                                              </block>
                                                                            </value>
                                                                            <value name="B">
                                                                              <block type="cond_compare">
                                                                                <field name="OP">&lt;</field>
                                                                                <value name="LEFT">
                                                                                  <block type="py_abs">
                                                                                    <value name="VALUE">
                                                                                      <block type="py_math_op">
                                                                                        <field name="OP">-</field>
                                                                                        <value name="LEFT"><block type="val_number"><field name="NUM">330</field></block></value>
                                                                                        <value name="RIGHT"><block type="val_var"><field name="VAR" id="g20c_iy">iy</field></block></value>
                                                                                      </block>
                                                                                    </value>
                                                                                  </block>
                                                                                </value>
                                                                                <value name="RIGHT"><block type="val_number"><field name="NUM">36</field></block></value>
                                                                              </block>
                                                                            </value>
                                                                          </block>
                                                                        </value>
                                                                        <statement name="DO0">
                                                                          <block type="pico_if">
                                                                            <value name="IF0">
                                                                              <block type="cond_compare">
                                                                                <field name="OP">==</field>
                                                                                <value name="LEFT"><block type="val_var"><field name="VAR" id="g20c_itype">itype</field></block></value>
                                                                                <value name="RIGHT"><block type="val_str"><field name="TEXT">star</field></block></value>
                                                                              </block>
                                                                            </value>
                                                                            <statement name="DO0">
                                                                              <block type="var_set">
                                                                                <field name="VAR" id="g20c_mult">mult</field>
                                                                                <value name="VALUE"><block type="val_number"><field name="NUM">3</field></block></value>
                                                                                <next>
                                                                                  <block type="var_set">
                                                                                    <field name="VAR" id="g20c_mtimer">mtimer</field>
                                                                                    <value name="VALUE">
                                                                                      <block type="py_math_op">
                                                                                        <field name="OP">+</field>
                                                                                        <value name="LEFT"><block type="game_get_ticks" /></value>
                                                                                        <value name="RIGHT">
                                                                                          <block type="py_math_op">
                                                                                            <field name="OP">*</field>
                                                                                            <value name="LEFT"><block type="val_number"><field name="NUM">5</field></block></value>
                                                                                            <value name="RIGHT"><block type="val_number"><field name="NUM">1000</field></block></value>
                                                                                          </block>
                                                                                        </value>
                                                                                      </block>
                                                                                    </value>
                                                                                  </block>
                                                                                </next>
                                                                              </block>
                                                                            </statement>
                                                                            <next>
                                                                              <block type="var_change">
                                                                                <field name="VAR" id="g20c_score">score</field>
                                                                                <value name="AMOUNT">
                                                                                  <block type="py_math_op">
                                                                                    <field name="OP">*</field>
                                                                                    <value name="LEFT"><block type="val_number"><field name="NUM">5</field></block></value>
                                                                                    <value name="RIGHT"><block type="val_var"><field name="VAR" id="g20c_mult">mult</field></block></value>
                                                                                  </block>
                                                                                </value>
                                                                                <next>
                                                                                  <block type="var_set">
                                                                                    <field name="VAR" id="g20c_iy">iy</field>
                                                                                    <value name="VALUE"><block type="val_number"><field name="NUM">-40</field></block></value>
                                                                                    <next>
                                                                                      <block type="var_set">
                                                                                        <field name="VAR" id="g20c_ix">ix</field>
                                                                                        <value name="VALUE"><block type="game_random_int"><field name="LO">0</field><field name="HI">600</field></block></value>
                                                                                        <next>
                                                                                          <block type="pico_if">
                                                                                            <mutation elseif="0" else="1" />
                                                                                            <value name="IF0">
