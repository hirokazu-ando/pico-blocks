                                                                                                <field name="OP">==</field>
                                                                                                <value name="LEFT">
                                                                                                  <block type="py_random_int">
                                                                                                    <value name="FROM"><block type="val_number"><field name="NUM">1</field></block></value>
                                                                                                    <value name="TO"><block type="val_number"><field name="NUM">8</field></block></value>
                                                                                                  </block>
                                                                                                </value>
                                                                                                <value name="RIGHT"><block type="val_number"><field name="NUM">1</field></block></value>
                                                                                              </block>
                                                                                            </value>
                                                                                            <statement name="DO0">
                                                                                              <block type="var_set">
                                                                                                <field name="VAR" id="g20c_itype">itype</field>
                                                                                                <value name="VALUE"><block type="val_str"><field name="TEXT">star</field></block></value>
                                                                                              </block>
                                                                                            </statement>
                                                                                            <statement name="ELSE">
                                                                                              <block type="var_set">
                                                                                                <field name="VAR" id="g20c_itype">itype</field>
                                                                                                <value name="VALUE"><block type="val_str"><field name="TEXT">coin</field></block></value>
                                                                                              </block>
                                                                                            </statement>
                                                                                          </block>
                                                                                        </next>
                                                                                      </block>
                                                                                    </next>
                                                                                  </block>
                                                                                </next>
                                                                              </block>
                                                                            </next>
                                                                          </block>
                                                                        </statement>
                                                                        <next>
                                                                          <block type="pico_if">
                                                                            <value name="IF0">
                                                                              <block type="cond_compare">
                                                                                <field name="OP">&gt;=</field>
                                                                                <value name="LEFT"><block type="game_get_ticks" /></value>
                                                                                <value name="RIGHT"><block type="val_var"><field name="VAR" id="g20c_mtimer">mtimer</field></block></value>
                                                                              </block>
                                                                            </value>
                                                                            <statement name="DO0">
                                                                              <block type="var_set">
                                                                                <field name="VAR" id="g20c_mult">mult</field>
                                                                                <value name="VALUE"><block type="val_number"><field name="NUM">1</field></block></value>
                                                                              </block>
                                                                            </statement>
                                                                            <next>
                                                                              <block type="game_draw_image">
                                                                                <value name="URL"><block type="game_image_preset"><field name="IMG">assets/game-icons/player_ship.svg</field></block></value>
                                                                                <value name="X"><block type="val_var"><field name="VAR" id="g20c_px">px</field></block></value>
                                                                                <value name="Y"><block type="val_number"><field name="NUM">330</field></block></value>
                                                                                <value name="W"><block type="val_number"><field name="NUM">48</field></block></value>
                                                                                <value name="H"><block type="val_number"><field name="NUM">48</field></block></value>
                                                                                <next>
                                                                                  <block type="pico_if">
                                                                                    <value name="IF0">
                                                                                      <block type="cond_compare">
                                                                                        <field name="OP">==</field>
                                                                                        <value name="LEFT"><block type="val_var"><field name="VAR" id="g20c_itype">itype</field></block></value>
                                                                                        <value name="RIGHT"><block type="val_str"><field name="TEXT">star</field></block></value>
                                                                                      </block>
                                                                                    </value>
                                                                                    <statement name="DO0">
                                                                                      <block type="game_draw_image">
                                                                                        <value name="URL"><block type="game_image_preset"><field name="IMG">assets/game-icons/star.svg</field></block></value>
                                                                                        <value name="X"><block type="val_var"><field name="VAR" id="g20c_ix">ix</field></block></value>
                                                                                        <value name="Y"><block type="val_var"><field name="VAR" id="g20c_iy">iy</field></block></value>
                                                                                        <value name="W"><block type="val_number"><field name="NUM">36</field></block></value>
                                                                                        <value name="H"><block type="val_number"><field name="NUM">36</field></block></value>
                                                                                      </block>
                                                                                    </statement>
                                                                                    <next>
                                                                                      <block type="pico_if">
                                                                                        <value name="IF0">
                                                                                          <block type="cond_compare">
                                                                                            <field name="OP">==</field>
                                                                                            <value name="LEFT"><block type="val_var"><field name="VAR" id="g20c_itype">itype</field></block></value>
                                                                                            <value name="RIGHT"><block type="val_str"><field name="TEXT">coin</field></block></value>
                                                                                          </block>
                                                                                        </value>
                                                                                        <statement name="DO0">
                                                                                          <block type="game_draw_image">
                                                                                            <value name="URL"><block type="game_image_preset"><field name="IMG">assets/game-icons/coin.svg</field></block></value>
                                                                                            <value name="X"><block type="val_var"><field name="VAR" id="g20c_ix">ix</field></block></value>
                                                                                            <value name="Y"><block type="val_var"><field name="VAR" id="g20c_iy">iy</field></block></value>
                                                                                            <value name="W"><block type="val_number"><field name="NUM">36</field></block></value>
                                                                                            <value name="H"><block type="val_number"><field name="NUM">36</field></block></value>
                                                                                          </block>
                                                                                        </statement>
                                                                                        <next>
                                                                                          <block type="game_draw_text">
                                                                                            <value name="TEXT">
                                                                                              <block type="py_fstring">
                                                                                                <field name="PRE">Score: </field>
                                                                                                <field name="POST"></field>
                                                                                                <value name="VAR"><block type="val_var"><field name="VAR" id="g20c_score">score</field></block></value>
                                                                                              </block>
                                                                                            </value>
                                                                                            <value name="X"><block type="val_number"><field name="NUM">10</field></block></value>
                                                                                            <value name="Y"><block type="val_number"><field name="NUM">10</field></block></value>
                                                                                            <value name="SIZE"><block type="val_number"><field name="NUM">24</field></block></value>
                                                                                            <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#ffffff</field></block></value>
                                                                                            <next>
                                                                                              <block type="game_draw_text">
                                                                                                <value name="TEXT">
                                                                                                  <block type="py_fstring">
                                                                                                    <field name="PRE">x</field>
                                                                                                    <field name="POST"></field>
                                                                                                    <value name="VAR"><block type="val_var"><field name="VAR" id="g20c_mult">mult</field></block></value>
                                                                                                  </block>
                                                                                                </value>
                                                                                                <value name="X"><block type="val_number"><field name="NUM">10</field></block></value>
                                                                                                <value name="Y"><block type="val_number"><field name="NUM">36</field></block></value>
                                                                                                <value name="SIZE"><block type="val_number"><field name="NUM">24</field></block></value>
                                                                                                <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#ffd700</field></block></value>
                                                                                                <next>
                                                                                                  <block type="game_flip">
                                                                                                    <value name="FPS"><block type="val_number"><field name="NUM">60</field></block></value>
                                                                                                  </block>
                                                                                                </next>
                                                                                              </block>
                                                                                            </next>
                                                                                          </block>
                                                                                        </next>
                                                                                      </block>
                                                                                    </next>
                                                                                  </block>
                                                                                </next>
                                                                              </block>
                                                                            </next>
                                                                          </block>
                                                                        </next>
                                                                      </block>
                                                                    </next>
                                                                  </block>
                                                                </next>
                                                              </block>
                                                            </next>
                                                          </block>
                                                        </next>
                                                      </block>
                                                    </next>
                                                  </block>
                                                </next>
                                              </block>
                                            </statement>
                                            <next><block type="game_quit" /></next>
                                          </block>
                                        </next>
                                      </block>
                                    </next>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
