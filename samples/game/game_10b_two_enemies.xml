<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vpx">px</variable>
    <variable id="ve1x">e1x</variable>
    <variable id="ve1y">e1y</variable>
    <variable id="ve2x">e2x</variable>
    <variable id="ve2y">e2y</variable>
  </variables>
  <block type="game_init" x="20" y="20">
    <value name="W"><block type="val_number"><field name="NUM">640</field></block></value>
    <value name="H"><block type="val_number"><field name="NUM">400</field></block></value>
    <value name="TITLE"><block type="val_str"><field name="TEXT">Two Enemies</field></block></value>
    <next>
      <block type="game_import_random">
        <next>
          <block type="var_set">
            <field name="VAR" id="vpx">px</field>
            <value name="VALUE"><block type="val_number"><field name="NUM">300</field></block></value>
            <next>
              <block type="var_set">
                <field name="VAR" id="ve1x">e1x</field>
                <value name="VALUE"><block type="game_random_int"><field name="LO">0</field><field name="HI">576</field></block></value>
                <next>
                  <block type="var_set">
                    <field name="VAR" id="ve1y">e1y</field>
                    <value name="VALUE"><block type="val_number"><field name="NUM">-48</field></block></value>
                    <next>
                      <block type="var_set">
                        <field name="VAR" id="ve2x">e2x</field>
                        <value name="VALUE"><block type="game_random_int"><field name="LO">0</field><field name="HI">576</field></block></value>
                        <next>
                          <block type="var_set">
                            <field name="VAR" id="ve2y">e2y</field>
                            <value name="VALUE"><block type="val_number"><field name="NUM">-96</field></block></value>
                            <next>
                              <block type="game_loop">
                                <statement name="DO">
                                  <block type="game_events">
                                    <next>
                                      <block type="game_fill">
                                        <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#0a0a2e</field></block></value>
                                        <next>
                                          <block type="var_change">
                                            <field name="VAR" id="ve1y">e1y</field>
                                            <value name="AMOUNT"><block type="val_number"><field name="NUM">3</field></block></value>
                                            <next>
                                              <block type="var_change">
                                                <field name="VAR" id="ve2y">e2y</field>
                                                <value name="AMOUNT"><block type="val_number"><field name="NUM">4</field></block></value>
                                                <next>
                                                  <block type="pico_if">
                                                    <value name="IF0">
                                                      <block type="cond_compare">
                                                        <field name="OP">&gt;</field>
                                                        <value name="LEFT"><block type="val_var"><field name="VAR" id="ve1y">e1y</field></block></value>
                                                        <value name="RIGHT"><block type="val_number"><field name="NUM">400</field></block></value>
                                                      </block>
                                                    </value>
                                                    <statement name="DO0">
                                                      <block type="var_set">
                                                        <field name="VAR" id="ve1y">e1y</field>
                                                        <value name="VALUE"><block type="val_number"><field name="NUM">-48</field></block></value>
                                                        <next>
                                                          <block type="var_set">
                                                            <field name="VAR" id="ve1x">e1x</field>
                                                            <value name="VALUE"><block type="game_random_int"><field name="LO">0</field><field name="HI">576</field></block></value>
                                                          </block>
                                                        </next>
                                                      </block>
                                                    </statement>
                                                    <next>
                                                      <block type="pico_if">
                                                        <value name="IF0">
                                                          <block type="cond_compare">
                                                            <field name="OP">&gt;</field>
                                                            <value name="LEFT"><block type="val_var"><field name="VAR" id="ve2y">e2y</field></block></value>
                                                            <value name="RIGHT"><block type="val_number"><field name="NUM">400</field></block></value>
                                                          </block>
                                                        </value>
                                                        <statement name="DO0">
                                                          <block type="var_set">
                                                            <field name="VAR" id="ve2y">e2y</field>
                                                            <value name="VALUE"><block type="val_number"><field name="NUM">-48</field></block></value>
                                                            <next>
                                                              <block type="var_set">
                                                                <field name="VAR" id="ve2x">e2x</field>
                                                                <value name="VALUE"><block type="game_random_int"><field name="LO">0</field><field name="HI">576</field></block></value>
                                                              </block>
                                                            </next>
                                                          </block>
                                                        </statement>
                                                        <next>
                                                          <block type="game_draw_image">
                                                            <value name="URL"><block type="game_image_preset"><field name="IMG">assets/game-icons/player_ship.svg</field></block></value>
                                                            <value name="X"><block type="val_var"><field name="VAR" id="vpx">px</field></block></value>
                                                            <value name="Y"><block type="val_number"><field name="NUM">340</field></block></value>
                                                            <value name="W"><block type="val_number"><field name="NUM">48</field></block></value>
                                                            <next>
                                                              <block type="game_draw_image">
                                                                <value name="URL"><block type="game_image_preset"><field name="IMG">assets/game-icons/enemy_bug.svg</field></block></value>
                                                                <value name="X"><block type="val_var"><field name="VAR" id="ve1x">e1x</field></block></value>
                                                                <value name="Y"><block type="val_var"><field name="VAR" id="ve1y">e1y</field></block></value>
                                                                <value name="W"><block type="val_number"><field name="NUM">48</field></block></value>
                                                                <next>
                                                                  <block type="game_draw_image">
                                                                    <value name="URL"><block type="game_image_preset"><field name="IMG">assets/game-icons/enemy_bug.svg</field></block></value>
                                                                    <value name="X"><block type="val_var"><field name="VAR" id="ve2x">e2x</field></block></value>
                                                                    <value name="Y"><block type="val_var"><field name="VAR" id="ve2y">e2y</field></block></value>
                                                                    <value name="W"><block type="val_number"><field name="NUM">48</field></block></value>
                                                                    <next>
                                                                      <block type="game_flip">
                                                                        <value name="FPS"><block type="val_number"><field name="NUM">60</field></block></value>
                                                                      </block>
                                                                    </next>
                                                                  </block>
                                                                </next>
                                                              </block>
                                                            </next>
                                                          </block>
                                                        </next>
                                                      </block>
                                                    </next>
                                                  </block>
                                                </next>
                                              </block>
                                            </next>
                                          </block>
                                        </next>
                                      </block>
                                    </next>
                                  </block>
                                </statement>
                                <next>
                                  <block type="game_quit"></block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
