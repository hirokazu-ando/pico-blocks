<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vpx">px</variable>
    <variable id="vex">ex</variable>
    <variable id="vey">ey</variable>
    <variable id="vs">score</variable>
    <variable id="vsp">speed</variable>
  </variables>
  <block type="game_init" x="20" y="20">
    <value name="W"><block type="val_number"><field name="NUM">640</field></block></value>
    <value name="H"><block type="val_number"><field name="NUM">400</field></block></value>
    <value name="TITLE"><block type="val_str"><field name="TEXT">Timer Difficulty</field></block></value>
    <next>
      <block type="game_import_random">
        <next>
          <block type="var_set">
            <field name="VAR" id="vpx">px</field>
            <value name="VALUE"><block type="val_number"><field name="NUM">300</field></block></value>
            <next>
              <block type="var_set">
                <field name="VAR" id="vex">ex</field>
                <value name="VALUE"><block type="game_random_int"><field name="LO">0</field><field name="HI">576</field></block></value>
                <next>
                  <block type="var_set">
                    <field name="VAR" id="vey">ey</field>
                    <value name="VALUE"><block type="val_number"><field name="NUM">-48</field></block></value>
                    <next>
                      <block type="var_set">
                        <field name="VAR" id="vs">score</field>
                        <value name="VALUE"><block type="val_number"><field name="NUM">0</field></block></value>
                        <next>
                          <block type="var_set">
                            <field name="VAR" id="vsp">speed</field>
                            <value name="VALUE"><block type="val_number"><field name="NUM">2</field></block></value>
                            <next>
                              <block type="game_loop">
                                <statement name="DO">
                                  <block type="game_events">
                                    <next>
                                      <block type="game_fill">
                                        <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#0a0a2e</field></block></value>
                                        <next>
                                          <block type="pico_if">
                                            <mutation elseif="0" else="0"></mutation>
                                            <value name="IF0"><block type="game_key_pressed"><field name="KEY">K_RIGHT</field></block></value>
                                            <statement name="DO0">
                                              <block type="var_change">
                                                <field name="VAR" id="vpx">px</field>
                                                <value name="AMOUNT"><block type="val_number"><field name="NUM">4</field></block></value>
                                              </block>
                                            </statement>
                                            <next>
                                              <block type="pico_if">
                                                <mutation elseif="0" else="0"></mutation>
                                                <value name="IF0"><block type="game_key_pressed"><field name="KEY">K_LEFT</field></block></value>
                                                <statement name="DO0">
                                                  <block type="var_change">
                                                    <field name="VAR" id="vpx">px</field>
                                                    <value name="AMOUNT"><block type="val_number"><field name="NUM">-4</field></block></value>
                                                  </block>
                                                </statement>
                                                <next>
                                                  <block type="var_set">
                                                    <field name="VAR" id="vsp">speed</field>
                                                    <value name="VALUE">
                                                      <block type="py_math_op">
                                                        <field name="OP">+</field>
                                                        <value name="LEFT"><block type="val_number"><field name="NUM">2</field></block></value>
                                                        <value name="RIGHT">
                                                          <block type="py_math_op">
                                                            <field name="OP">//</field>
                                                            <value name="LEFT"><block type="game_get_ticks"></block></value>
                                                            <value name="RIGHT"><block type="val_number"><field name="NUM">5000</field></block></value>
                                                          </block>
                                                        </value>
                                                      </block>
                                                    </value>
                                                    <next>
                                                      <block type="var_change">
                                                        <field name="VAR" id="vey">ey</field>
                                                        <value name="AMOUNT"><block type="val_var"><field name="VAR" id="vsp">speed</field></block></value>
                                                        <next>
                                                          <block type="pico_if">
                                                            <mutation elseif="0" else="0"></mutation>
                                                            <value name="IF0">
                                                              <block type="cond_compare">
                                                                <field name="OP">&gt;</field>
                                                                <value name="LEFT"><block type="val_var"><field name="VAR" id="vey">ey</field></block></value>
                                                                <value name="RIGHT"><block type="val_number"><field name="NUM">400</field></block></value>
                                                              </block>
                                                            </value>
                                                            <statement name="DO0">
                                                              <block type="var_set">
                                                                <field name="VAR" id="vey">ey</field>
                                                                <value name="VALUE"><block type="val_number"><field name="NUM">-48</field></block></value>
                                                                <next>
                                                                  <block type="var_set">
                                                                    <field name="VAR" id="vex">ex</field>
                                                                    <value name="VALUE"><block type="game_random_int"><field name="LO">0</field><field name="HI">576</field></block></value>
                                                                    <next>
                                                                      <block type="var_change">
                                                                        <field name="VAR" id="vs">score</field>
                                                                        <value name="AMOUNT"><block type="val_number"><field name="NUM">1</field></block></value>
                                                                      </block>
                                                                    </next>
                                                                  </block>
                                                                </next>
                                                              </block>
                                                            </statement>
                                                            <next>
                                                              <block type="game_draw_image">
                                                                <value name="URL"><block type="game_image_preset"><field name="IMG">assets/game-icons/player_ship.svg</field></block></value>
                                                                <value name="X"><block type="val_var"><field name="VAR" id="vpx">px</field></block></value>
                                                                <value name="Y"><block type="val_number"><field name="NUM">330</field></block></value>
                                                                <value name="W"><block type="val_number"><field name="NUM">48</field></block></value>
                                                                <next>
                                                                  <block type="game_draw_image">
                                                                    <value name="URL"><block type="game_image_preset"><field name="IMG">assets/game-icons/enemy_bug.svg</field></block></value>
                                                                    <value name="X"><block type="val_var"><field name="VAR" id="vex">ex</field></block></value>
                                                                    <value name="Y"><block type="val_var"><field name="VAR" id="vey">ey</field></block></value>
                                                                    <value name="W"><block type="val_number"><field name="NUM">48</field></block></value>
                                                                    <next>
                                                                      <block type="game_draw_text">
                                                                        <value name="TEXT">
                                                                          <block type="py_fstring">
                                                                            <field name="PRE">速度: </field>
                                                                            <field name="POST"></field>
                                                                            <value name="VAR"><block type="val_var"><field name="VAR" id="vsp">speed</field></block></value>
                                                                          </block>
                                                                        </value>
                                                                        <value name="X"><block type="val_number"><field name="NUM">10</field></block></value>
                                                                        <value name="Y"><block type="val_number"><field name="NUM">10</field></block></value>
                                                                        <value name="SIZE"><block type="val_number"><field name="NUM">22</field></block></value>
                                                                        <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#aaaaff</field></block></value>
                                                                        <next>
                                                                          <block type="game_draw_text">
                                                                            <value name="TEXT">
                                                                              <block type="py_fstring">
                                                                                <field name="PRE">Score: </field>
                                                                                <field name="POST"></field>
                                                                                <value name="VAR"><block type="val_var"><field name="VAR" id="vs">score</field></block></value>
                                                                              </block>
                                                                            </value>
                                                                            <value name="X"><block type="val_number"><field name="NUM">400</field></block></value>
                                                                            <value name="Y"><block type="val_number"><field name="NUM">10</field></block></value>
                                                                            <value name="SIZE"><block type="val_number"><field name="NUM">22</field></block></value>
                                                                            <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#ffffff</field></block></value>
                                                                            <next>
                                                                              <block type="game_flip">
                                                                                <value name="FPS"><block type="val_number"><field name="NUM">60</field></block></value>
                                                                              </block>
                                                                            </next>
                                                                          </block>
                                                                        </next>
                                                                      </block>
                                                                    </next>
                                                                  </block>
                                                                </next>
                                                              </block>
                                                            </next>
                                                          </block>
                                                        </next>
                                                      </block>
                                                    </next>
                                                  </block>
                                                </next>
                                              </block>
                                            </next>
                                          </block>
                                        </next>
                                      </block>
                                    </next>
                                  </block>
                                </statement>
                                <next>
                                  <block type="game_quit"></block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
