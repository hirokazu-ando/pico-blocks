<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="g19a_px">px</variable>
    <variable id="g19a_ex">ex</variable>
    <variable id="g19a_ey">ey</variable>
    <variable id="g19a_bul">bullets</variable>
    <variable id="g19a_b">b</variable>
    <variable id="g19a_run">running</variable>
  </variables>
  <block type="game_import_random" x="20" y="20">
    <next>
      <block type="game_init">
        <value name="W"><block type="val_number"><field name="NUM">640</field></block></value>
        <value name="H"><block type="val_number"><field name="NUM">400</field></block></value>
        <value name="TITLE"><block type="val_str"><field name="TEXT">Bullet Hit Enemy</field></block></value>
        <next>
          <block type="var_set">
            <field name="VAR" id="g19a_px">px</field>
            <value name="VALUE"><block type="val_number"><field name="NUM">300</field></block></value>
            <next>
              <block type="var_set">
                <field name="VAR" id="g19a_ex">ex</field>
                <value name="VALUE"><block type="game_random_int"><field name="LO">0</field><field name="HI">576</field></block></value>
                <next>
                  <block type="var_set">
                    <field name="VAR" id="g19a_ey">ey</field>
                    <value name="VALUE"><block type="val_number"><field name="NUM">-48</field></block></value>
                    <next>
                      <block type="var_set">
                        <field name="VAR" id="g19a_bul">bullets</field>
                        <value name="VALUE"><block type="py_list_empty" /></value>
                        <next>
                          <block type="var_set">
                            <field name="VAR" id="g19a_run">running</field>
                            <value name="VALUE"><block type="val_bool"><field name="BOOL">True</field></block></value>
                            <next>
                              <block type="game_loop">
                                <statement name="DO">
                                  <block type="game_events">
                                    <next>
                                      <block type="game_fill">
                                        <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#0a0a2e</field></block></value>
                                        <next>
                                          <block type="pico_if">
                                            <value name="IF0"><block type="game_key_pressed"><field name="KEY">K_RIGHT</field></block></value>
                                            <statement name="DO0">
                                              <block type="var_change">
                                                <field name="VAR" id="g19a_px">px</field>
                                                <value name="AMOUNT"><block type="val_number"><field name="NUM">4</field></block></value>
                                              </block>
                                            </statement>
                                            <next>
                                              <block type="pico_if">
                                                <value name="IF0"><block type="game_key_pressed"><field name="KEY">K_LEFT</field></block></value>
                                                <statement name="DO0">
                                                  <block type="var_change">
                                                    <field name="VAR" id="g19a_px">px</field>
                                                    <value name="AMOUNT"><block type="val_number"><field name="NUM">-4</field></block></value>
                                                  </block>
                                                </statement>
                                                <next>
                                                  <block type="pico_if">
                                                    <value name="IF0"><block type="game_key_pressed"><field name="KEY">K_SPACE</field></block></value>
                                                    <statement name="DO0">
                                                      <block type="py_list_append">
                                                        <field name="LIST" id="g19a_bul">bullets</field>
                                                        <value name="VALUE">
                                                          <block type="py_list_literal">
                                                            <mutation items="2" />
                                                            <value name="ITEM0">
                                                              <block type="py_math_op">
                                                                <field name="OP">+</field>
                                                                <value name="LEFT"><block type="val_var"><field name="VAR" id="g19a_px">px</field></block></value>
                                                                <value name="RIGHT"><block type="val_number"><field name="NUM">20</field></block></value>
                                                              </block>
                                                            </value>
                                                            <value name="ITEM1"><block type="val_number"><field name="NUM">330</field></block></value>
                                                          </block>
                                                        </value>
                                                      </block>
                                                    </statement>
                                                    <next>
                                                      <block type="var_change">
                                                        <field name="VAR" id="g19a_ey">ey</field>
                                                        <value name="AMOUNT"><block type="val_number"><field name="NUM">3</field></block></value>
                                                        <next>
                                                          <block type="pico_if">
                                                            <value name="IF0">
                                                              <block type="cond_compare">
                                                                <field name="OP">&gt;</field>
                                                                <value name="LEFT"><block type="val_var"><field name="VAR" id="g19a_ey">ey</field></block></value>
                                                                <value name="RIGHT"><block type="val_number"><field name="NUM">400</field></block></value>
                                                              </block>
                                                            </value>
                                                            <statement name="DO0">
                                                              <block type="var_set">
                                                                <field name="VAR" id="g19a_ey">ey</field>
                                                                <value name="VALUE"><block type="val_number"><field name="NUM">-48</field></block></value>
                                                                <next>
                                                                  <block type="var_set">
                                                                    <field name="VAR" id="g19a_ex">ex</field>
                                                                    <value name="VALUE"><block type="game_random_int"><field name="LO">0</field><field name="HI">576</field></block></value>
                                                                  </block>
                                                                </next>
                                                              </block>
                                                            </statement>
                                                            <next>
                                                              <block type="py_for_list">
                                                                <field name="VAR" id="g19a_b">b</field>
                                                                <field name="LIST" id="g19a_bul">bullets</field>
                                                                <statement name="DO">
                                                                  <block type="py_list_set">
                                                                    <field name="LIST" id="g19a_b">b</field>
                                                                    <value name="INDEX"><block type="val_number"><field name="NUM">1</field></block></value>
                                                                    <value name="VALUE"><block type="py_custom_expr"><field name="CODE">b[1] - 6</field></block></value>
                                                                    <next>
                                                                      <block type="pico_if">
                                                                        <value name="IF0">
                                                                          <block type="cond_and">
                                                                            <value name="A">
                                                                              <block type="cond_compare">
                                                                                <field name="OP">&lt;</field>
                                                                                <value name="LEFT">
                                                                                  <block type="py_abs">
                                                                                    <value name="VALUE">
                                                                                      <block type="py_math_op">
                                                                                        <field name="OP">-</field>
                                                                                        <value name="LEFT">
                                                                                          <block type="py_list_get">
                                                                                            <field name="LIST" id="g19a_b">b</field>
                                                                                            <value name="INDEX"><block type="val_number"><field name="NUM">0</field></block></value>
                                                                                          </block>
                                                                                        </value>
                                                                                        <value name="RIGHT"><block type="val_var"><field name="VAR" id="g19a_ex">ex</field></block></value>
                                                                                      </block>
                                                                                    </value>
                                                                                  </block>
                                                                                </value>
                                                                                <value name="RIGHT"><block type="val_number"><field name="NUM">30</field></block></value>
                                                                              </block>
                                                                            </value>
                                                                            <value name="B">
                                                                              <block type="cond_compare">
                                                                                <field name="OP">&lt;</field>
                                                                                <value name="LEFT">
                                                                                  <block type="py_abs">
                                                                                    <value name="VALUE">
                                                                                      <block type="py_math_op">
                                                                                        <field name="OP">-</field>
                                                                                        <value name="LEFT">
                                                                                          <block type="py_list_get">
                                                                                            <field name="LIST" id="g19a_b">b</field>
                                                                                            <value name="INDEX"><block type="val_number"><field name="NUM">1</field></block></value>
                                                                                          </block>
                                                                                        </value>
                                                                                        <value name="RIGHT"><block type="val_var"><field name="VAR" id="g19a_ey">ey</field></block></value>
                                                                                      </block>
                                                                                    </value>
                                                                                  </block>
                                                                                </value>
                                                                                <value name="RIGHT"><block type="val_number"><field name="NUM">30</field></block></value>
                                                                              </block>
                                                                            </value>
                                                                          </block>
                                                                        </value>
                                                                        <statement name="DO0">
                                                                          <block type="var_set">
                                                                            <field name="VAR" id="g19a_ey">ey</field>
                                                                            <value name="VALUE"><block type="val_number"><field name="NUM">-48</field></block></value>
                                                                            <next>
                                                                              <block type="var_set">
                                                                                <field name="VAR" id="g19a_ex">ex</field>
                                                                                <value name="VALUE"><block type="game_random_int"><field name="LO">0</field><field name="HI">576</field></block></value>
                                                                                <next>
                                                                                  <block type="py_list_set">
                                                                                    <field name="LIST" id="g19a_b">b</field>
                                                                                    <value name="INDEX"><block type="val_number"><field name="NUM">1</field></block></value>
                                                                                    <value name="VALUE"><block type="val_number"><field name="NUM">-1000</field></block></value>
                                                                                  </block>
                                                                                </next>
                                                                              </block>
                                                                            </next>
                                                                          </block>
                                                                        </statement>
                                                                      </block>
                                                                    </next>
                                                                  </block>
                                                                </statement>
                                                                <next>
                                                                  <block type="game_draw_image">
                                                                    <value name="URL"><block type="game_image_preset"><field name="IMG">assets/game-icons/player_ship.svg</field></block></value>
                                                                    <value name="X"><block type="val_var"><field name="VAR" id="g19a_px">px</field></block></value>
                                                                    <value name="Y"><block type="val_number"><field name="NUM">330</field></block></value>
                                                                    <value name="W"><block type="val_number"><field name="NUM">48</field></block></value>
                                                                    <value name="H"><block type="val_number"><field name="NUM">48</field></block></value>
                                                                    <next>
                                                                      <block type="game_draw_image">
                                                                        <value name="URL"><block type="game_image_preset"><field name="IMG">assets/game-icons/enemy_bug.svg</field></block></value>
                                                                        <value name="X"><block type="val_var"><field name="VAR" id="g19a_ex">ex</field></block></value>
                                                                        <value name="Y"><block type="val_var"><field name="VAR" id="g19a_ey">ey</field></block></value>
                                                                        <value name="W"><block type="val_number"><field name="NUM">48</field></block></value>
                                                                        <value name="H"><block type="val_number"><field name="NUM">48</field></block></value>
                                                                        <next>
                                                                          <block type="py_for_list">
                                                                            <field name="VAR" id="g19a_b">b</field>
                                                                            <field name="LIST" id="g19a_bul">bullets</field>
                                                                            <statement name="DO">
                                                                              <block type="game_draw_image">
                                                                                <value name="URL"><block type="game_image_preset"><field name="IMG">assets/game-icons/bullet.svg</field></block></value>
                                                                                <value name="X">
                                                                                  <block type="py_list_get">
                                                                                    <field name="LIST" id="g19a_b">b</field>
                                                                                    <value name="INDEX"><block type="val_number"><field name="NUM">0</field></block></value>
                                                                                  </block>
                                                                                </value>
                                                                                <value name="Y">
                                                                                  <block type="py_list_get">
                                                                                    <field name="LIST" id="g19a_b">b</field>
                                                                                    <value name="INDEX"><block type="val_number"><field name="NUM">1</field></block></value>
                                                                                  </block>
                                                                                </value>
                                                                                <value name="W"><block type="val_number"><field name="NUM">16</field></block></value>
                                                                                <value name="H"><block type="val_number"><field name="NUM">24</field></block></value>
                                                                              </block>
                                                                            </statement>
                                                                            <next>
                                                                              <block type="game_flip">
                                                                                <value name="FPS"><block type="val_number"><field name="NUM">60</field></block></value>
                                                                              </block>
                                                                            </next>
                                                                          </block>
                                                                        </next>
                                                                      </block>
                                                                    </next>
                                                                  </block>
                                                                </next>
                                                              </block>
                                                            </next>
                                                          </block>
                                                        </next>
                                                      </block>
                                                    </next>
                                                  </block>
                                                </next>
                                              </block>
                                            </next>
                                          </block>
                                        </next>
                                      </block>
                                    </next>
                                  </block>
                                </statement>
                                <next>
                                  <block type="game_quit" />
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
