<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vship">SHIP</variable>
  </variables>
  <block type="game_init">
    <value name="W"><block type="val_number"><field name="NUM">640</field></block></value>
    <value name="H"><block type="val_number"><field name="NUM">400</field></block></value>
    <value name="TITLE"><block type="val_str"><field name="TEXT">Three Ships</field></block></value>
    <next>
      <block type="var_set">
        <field name="VAR" id="vship">SHIP</field>
        <value name="VALUE">
          <block type="game_image_preset">
            <field name="IMG">assets/game-icons/player_ship.svg</field>
          </block>
        </value>
        <next>
          <block type="game_loop">
            <statement name="DO">
              <block type="game_events">
                <next>
                  <block type="game_fill">
                    <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#000030</field></block></value>
                    <next>
                      <block type="game_draw_image">
                        <value name="URL"><block type="val_var"><field name="VAR" id="vship">SHIP</field></block></value>
                        <value name="X"><block type="val_number"><field name="NUM">80</field></block></value>
                        <value name="Y"><block type="val_number"><field name="NUM">180</field></block></value>
                        <value name="W"><block type="val_number"><field name="NUM">48</field></block></value>
                        <value name="H"><block type="val_number"><field name="NUM">48</field></block></value>
                        <next>
                          <block type="game_draw_image">
                            <value name="URL"><block type="val_var"><field name="VAR" id="vship">SHIP</field></block></value>
                            <value name="X"><block type="val_number"><field name="NUM">296</field></block></value>
                            <value name="Y"><block type="val_number"><field name="NUM">180</field></block></value>
                            <value name="W"><block type="val_number"><field name="NUM">48</field></block></value>
                            <value name="H"><block type="val_number"><field name="NUM">48</field></block></value>
                            <next>
                              <block type="game_draw_image">
                                <value name="URL"><block type="val_var"><field name="VAR" id="vship">SHIP</field></block></value>
                                <value name="X"><block type="val_number"><field name="NUM">512</field></block></value>
                                <value name="Y"><block type="val_number"><field name="NUM">180</field></block></value>
                                <value name="W"><block type="val_number"><field name="NUM">48</field></block></value>
                                <value name="H"><block type="val_number"><field name="NUM">48</field></block></value>
                                <next>
                                  <block type="game_flip">
                                    <value name="FPS"><block type="val_number"><field name="NUM">60</field></block></value>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </statement>
            <next>
              <block type="game_quit" />
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
