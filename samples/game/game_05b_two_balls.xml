<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="v1x">b1x</variable>
    <variable id="v1y">b1y</variable>
    <variable id="v2x">b2x</variable>
    <variable id="v2y">b2y</variable>
  </variables>
  <block type="game_init" x="20" y="20">
    <value name="W"><block type="val_number"><field name="NUM">640</field></block></value>
    <value name="H"><block type="val_number"><field name="NUM">400</field></block></value>
    <value name="TITLE"><block type="val_str"><field name="TEXT">Two Balls</field></block></value>
    <next>
      <block type="var_set">
        <field name="VAR" id="v1x">b1x</field>
        <value name="VALUE"><block type="val_number"><field name="NUM">320</field></block></value>
        <next>
          <block type="var_set">
            <field name="VAR" id="v1y">b1y</field>
            <value name="VALUE"><block type="val_number"><field name="NUM">50</field></block></value>
            <next>
              <block type="var_set">
                <field name="VAR" id="v2x">b2x</field>
                <value name="VALUE"><block type="val_number"><field name="NUM">100</field></block></value>
                <next>
                  <block type="var_set">
                    <field name="VAR" id="v2y">b2y</field>
                    <value name="VALUE"><block type="val_number"><field name="NUM">200</field></block></value>
                    <next>
                      <block type="game_loop">
                        <statement name="DO">
                          <block type="game_events">
                            <next>
                              <block type="game_fill">
                                <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#1a1a2e</field></block></value>
                                <next>
                                  <block type="var_change">
                                    <field name="VAR" id="v1x">b1x</field>
                                    <value name="AMOUNT"><block type="val_number"><field name="NUM">4</field></block></value>
                                    <next>
                                      <block type="var_change">
                                        <field name="VAR" id="v1y">b1y</field>
                                        <value name="AMOUNT"><block type="val_number"><field name="NUM">3</field></block></value>
                                        <next>
                                          <block type="var_change">
                                            <field name="VAR" id="v2x">b2x</field>
                                            <value name="AMOUNT"><block type="val_number"><field name="NUM">3</field></block></value>
                                            <next>
                                              <block type="var_change">
                                                <field name="VAR" id="v2y">b2y</field>
                                                <value name="AMOUNT"><block type="val_number"><field name="NUM">2</field></block></value>
                                                <next>
                                                  <block type="game_draw_circle">
                                                    <value name="X"><block type="val_var"><field name="VAR" id="v1x">b1x</field></block></value>
                                                    <value name="Y"><block type="val_var"><field name="VAR" id="v1y">b1y</field></block></value>
                                                    <value name="R"><block type="val_number"><field name="NUM">15</field></block></value>
                                                    <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#ff5722</field></block></value>
                                                    <next>
                                                      <block type="game_draw_circle">
                                                        <value name="X"><block type="val_var"><field name="VAR" id="v2x">b2x</field></block></value>
                                                        <value name="Y"><block type="val_var"><field name="VAR" id="v2y">b2y</field></block></value>
                                                        <value name="R"><block type="val_number"><field name="NUM">12</field></block></value>
                                                        <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#00bcd4</field></block></value>
                                                        <next>
                                                          <block type="game_flip">
                                                            <value name="FPS"><block type="val_number"><field name="NUM">60</field></block></value>
                                                          </block>
                                                        </next>
                                                      </block>
                                                    </next>
                                                  </block>
                                                </next>
                                              </block>
                                            </next>
                                          </block>
                                        </next>
                                      </block>
                                    </next>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </statement>
                        <next>
                          <block type="game_quit"></block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
