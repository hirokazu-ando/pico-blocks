<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vli">lives</variable>
    <variable id="vi">i</variable>
  </variables>
  <block type="game_init" x="20" y="20">
    <value name="W"><block type="val_number"><field name="NUM">640</field></block></value>
    <value name="H"><block type="val_number"><field name="NUM">400</field></block></value>
    <value name="TITLE"><block type="val_str"><field name="TEXT">Lives</field></block></value>
    <next>
      <block type="var_set">
        <field name="VAR" id="vli">lives</field>
        <value name="VALUE"><block type="val_number"><field name="NUM">3</field></block></value>
        <next>
          <block type="game_loop">
            <statement name="DO">
              <block type="game_events">
                <next>
                  <block type="game_fill">
                    <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#1a237e</field></block></value>
                    <next>
                      <block type="pico_for_from_to">
                        <field name="VAR" id="vi">i</field>
                        <value name="START"><block type="val_number"><field name="NUM">0</field></block></value>
                        <value name="STOP"><block type="val_var"><field name="VAR" id="vli">lives</field></block></value>
                        <value name="STEP"><block type="val_number"><field name="NUM">1</field></block></value>
                        <statement name="DO">
                          <block type="game_draw_image">
                            <field name="FLIP">NONE</field>
                            <value name="URL">
                              <block type="game_image_preset">
                                <field name="IMG">assets/game-icons/heart.svg</field>
                              </block>
                            </value>
                            <value name="X">
                              <block type="py_math_op">
                                <field name="OP">+</field>
                                <value name="LEFT"><block type="val_number"><field name="NUM">20</field></block></value>
                                <value name="RIGHT">
                                  <block type="py_math_op">
                                    <field name="OP">*</field>
                                    <value name="LEFT"><block type="val_var"><field name="VAR" id="vi">i</field></block></value>
                                    <value name="RIGHT"><block type="val_number"><field name="NUM">44</field></block></value>
                                  </block>
                                </value>
                              </block>
                            </value>
                            <value name="Y"><block type="val_number"><field name="NUM">10</field></block></value>
                            <value name="W"><block type="val_number"><field name="NUM">40</field></block></value>
                            <value name="H"><block type="val_number"><field name="NUM">40</field></block></value>
                            <value name="ROT"><block type="val_number"><field name="NUM">0</field></block></value>
                          </block>
                        </statement>
                        <next>
                          <block type="game_draw_text">
                            <value name="TEXT"><block type="val_str"><field name="TEXT">Lives</field></block></value>
                            <value name="X"><block type="val_number"><field name="NUM">270</field></block></value>
                            <value name="Y"><block type="val_number"><field name="NUM">180</field></block></value>
                            <value name="SIZE"><block type="val_number"><field name="NUM">36</field></block></value>
                            <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#ffffff</field></block></value>
                            <next>
                              <block type="game_flip">
                                <value name="FPS"><block type="val_number"><field name="NUM">60</field></block></value>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </statement>
            <next>
              <block type="game_quit"></block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
