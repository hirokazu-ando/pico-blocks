<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vm">marks</variable>
    <variable id="vit">m</variable>
  </variables>
  <block type="game_init" x="20" y="20">
    <value name="W"><block type="val_number"><field name="NUM">640</field></block></value>
    <value name="H"><block type="val_number"><field name="NUM">400</field></block></value>
    <value name="TITLE"><block type="val_str"><field name="TEXT">Remove Nearest</field></block></value>
    <next>
      <block type="var_set">
        <field name="VAR" id="vm">marks</field>
        <value name="VALUE"><block type="py_list_empty"></block></value>
        <next>
          <block type="game_loop">
            <statement name="DO">
              <block type="game_events">
                <next>
                  <block type="game_fill">
                    <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#1a237e</field></block></value>
                    <next>
                      <block type="pico_if">
                        <value name="IF0"><block type="game_mouse_pressed"><field name="BTN">0</field></block></value>
                        <statement name="DO0">
                          <block type="py_list_append">
                            <field name="LIST" id="vm">marks</field>
                            <value name="VALUE">
                              <block type="py_list_literal">
                                <mutation items="2"></mutation>
                                <value name="ITEM0"><block type="game_mouse_x"></block></value>
                                <value name="ITEM1"><block type="game_mouse_y"></block></value>
                              </block>
                            </value>
                          </block>
                        </statement>
                        <next>
                          <block type="pico_if">
                            <value name="IF0">
                              <block type="cond_and">
                                <value name="A"><block type="game_mouse_pressed"><field name="BTN">2</field></block></value>
                                <value name="B"><block type="val_var"><field name="VAR" id="vm">marks</field></block></value>
                              </block>
                            </value>
                            <statement name="DO0">
                              <block type="py_list_pop">
                                <field name="LIST" id="vm">marks</field>
                              </block>
                            </statement>
                            <next>
                              <block type="py_for_list">
                                <field name="VAR" id="vit">m</field>
                                <field name="LIST" id="vm">marks</field>
                                <statement name="DO">
                                  <block type="game_draw_circle">
                                    <value name="X">
                                      <block type="py_list_get">
                                        <field name="LIST" id="vit">m</field>
                                        <value name="INDEX"><block type="val_number"><field name="NUM">0</field></block></value>
                                      </block>
                                    </value>
                                    <value name="Y">
                                      <block type="py_list_get">
                                        <field name="LIST" id="vit">m</field>
                                        <value name="INDEX"><block type="val_number"><field name="NUM">1</field></block></value>
                                      </block>
                                    </value>
                                    <value name="R"><block type="val_number"><field name="NUM">8</field></block></value>
                                    <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#ffc832</field></block></value>
                                  </block>
                                </statement>
                                <next>
                                  <block type="game_flip">
                                    <value name="FPS"><block type="val_number"><field name="NUM">60</field></block></value>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </statement>
            <next>
              <block type="game_quit"></block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
