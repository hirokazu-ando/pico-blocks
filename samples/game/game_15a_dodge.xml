<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vscore">score</variable>
  </variables>
  <block type="game_init" x="30" y="30">
    <value name="W"><block type="val_number"><field name="NUM">640</field></block></value>
    <value name="H"><block type="val_number"><field name="NUM">400</field></block></value>
    <value name="TITLE"><block type="val_str"><field name="TEXT">よけゲーム</field></block></value>
    <next><block type="game_import_random"><next>
    <block type="py_custom_stmt"><field name="CODE">ship_url  = 'assets/game-icons/player_ship.png'</field><next>
    <block type="py_custom_stmt"><field name="CODE">enemy_url = 'assets/game-icons/enemy_bug.png'</field><next>
    <block type="py_custom_stmt"><field name="CODE">coin_url  = 'assets/game-icons/coin.png'</field><next>
    <block type="py_custom_stmt"><field name="CODE">px, py   = 300, 320</field><next>
    <block type="py_custom_stmt"><field name="CODE">ex, ey   = random.randint(0, 576), -48</field><next>
    <block type="py_custom_stmt"><field name="CODE">cx, cy   = random.randint(0, 600), random.randint(50, 300)</field><next>
    <block type="var_set"><field name="VAR" id="vscore">score</field>
      <value name="VALUE"><block type="val_number"><field name="NUM">0</field></block></value>
      <next>
    <block type="py_custom_stmt"><field name="CODE">state  = 'play'</field><next>
    <block type="py_custom_stmt"><field name="CODE">start_t = pygame.time.get_ticks()</field><next>
    <block type="game_loop"><statement name="DO">
      <block type="game_events"><next>
      <block type="game_fill">
        <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#1a002a</field></block></value>
        <next>
      <block type="py_custom_stmt"><field name="CODE">elapsed = (pygame.time.get_ticks() - start_t) / 1000</field><next>
      <block type="py_custom_stmt"><field name="CODE">remain  = max(0, 30 - elapsed)</field><next>
      <block type="py_custom_stmt"><field name="CODE">espeed  = int(3 + elapsed // 4)</field><next>
      <block type="py_custom_stmt"><field name="CODE">if state == 'play':</field><next>
      <block type="py_custom_stmt"><field name="CODE">    keys = pygame.key.get_pressed()</field><next>
      <block type="py_custom_stmt"><field name="CODE">    if keys[pygame.K_RIGHT]: px = min(576, px + 5)</field><next>
      <block type="py_custom_stmt"><field name="CODE">    if keys[pygame.K_LEFT]:  px = max(0,   px - 5)</field><next>
      <block type="py_custom_stmt"><field name="CODE">    ey += espeed</field><next>
      <block type="py_custom_stmt"><field name="CODE">    if ey &gt; 400: ex = random.randint(0, 576); ey = -48</field><next>
      <block type="py_custom_stmt"><field name="CODE">    pr = pygame.Rect(px, py, 64, 64)</field><next>
      <block type="py_custom_stmt"><field name="CODE">    er = pygame.Rect(ex, ey, 64, 64)</field><next>
      <block type="py_custom_stmt"><field name="CODE">    cr = pygame.Rect(cx, cy, 32, 32)</field><next>
      <block type="py_custom_stmt"><field name="CODE">    if pr.colliderect(er): state = 'over'</field><next>
      <block type="py_custom_stmt"><field name="CODE">    if pr.colliderect(cr): score += 15; cx, cy = random.randint(0,600), random.randint(50,300)</field><next>
      <block type="py_custom_stmt"><field name="CODE">    if remain &lt;= 0: state = 'clear'</field><next>
      <block type="py_custom_stmt"><field name="CODE">    pyco_game.draw_image(ship_url,  px, py, 64, 64)</field><next>
      <block type="py_custom_stmt"><field name="CODE">    pyco_game.draw_image(enemy_url, ex, ey, 64, 64)</field><next>
      <block type="py_custom_stmt"><field name="CODE">    pyco_game.draw_image(coin_url,  cx, cy, 32, 32)</field><next>
      <block type="py_custom_stmt"><field name="CODE">    pyco_game.draw_text(f"Score:{score}  Time:{int(remain)}s", 10, 10, 22, "#ffffff")</field><next>
      <block type="py_custom_stmt"><field name="CODE">elif state == 'over':</field><next>
      <block type="py_custom_stmt"><field name="CODE">    pyco_game.draw_text("GAME OVER", 180, 160, 48, "#ff4444")</field><next>
      <block type="py_custom_stmt"><field name="CODE">    pyco_game.draw_text("Rキーでリスタート", 220, 220, 28, "#ffffff")</field><next>
      <block type="py_custom_stmt"><field name="CODE">    if pygame.key.get_pressed()[pygame.K_r]:</field><next>
      <block type="py_custom_stmt"><field name="CODE">        px,py=300,320; ex,ey=random.randint(0,576),-48; cx,cy=random.randint(0,600),random.randint(50,300); score=0; state='play'; start_t=pygame.time.get_ticks()</field><next>
      <block type="py_custom_stmt"><field name="CODE">elif state == 'clear':</field><next>
      <block type="py_custom_stmt"><field name="CODE">    pyco_game.draw_text("CLEAR!", 230, 160, 48, "#ffdd00")</field><next>
      <block type="py_custom_stmt"><field name="CODE">    pyco_game.draw_text(f"最終スコア: {score}", 220, 220, 28, "#ffffff")</field><next>
      <block type="game_flip">
        <value name="FPS"><block type="val_number"><field name="NUM">60</field></block></value>
      </block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
      </next></block>
    </statement><next>
    <block type="game_quit"></block>
    </next></block>
    </next></block>
    </next></block>
    </next></block>
    </next></block>
    </next></block>
    </next></block>
    </next></block>
    </next></block>
    </next></block>
    </next></block>
    </next></block>
  </block>
</xml>
