<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vid_px">player_x</variable>
    <variable id="vid_py">player_y</variable>
  </variables>
  <block type="game_init" id="init1" x="10" y="10">
    <value name="W">
      <block type="val_number"><field name="NUM">480</field></block>
    </value>
    <value name="H">
      <block type="val_number"><field name="NUM">320</field></block>
    </value>
    <value name="TITLE">
      <block type="val_str"><field name="TEXT">Sample 02 Arrow keys</field></block>
    </value>
    <next>
      <block type="var_set" id="set0">
        <field name="VAR" id="vid_px">player_x</field>
        <value name="VALUE"><block type="val_number"><field name="NUM">220</field></block></value>
        <next>
          <block type="var_set" id="set1">
            <field name="VAR" id="vid_py">player_y</field>
            <value name="VALUE"><block type="val_number"><field name="NUM">140</field></block></value>
            <next>
              <block type="game_loop" id="loop1">
                <statement name="DO">
                  <block type="game_events" id="ev1">
                    <next>
                      <block type="game_fill" id="fill1">
                        <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#263238</field></block></value>
                        <next>
                          <block type="pico_if" id="ifr">
                            <value name="IF0">
                              <block type="game_key_pressed" id="kr">
                                <field name="KEY">K_RIGHT</field>
                              </block>
                            </value>
                            <statement name="DO0">
                              <block type="var_change" id="ch1">
                                <field name="VAR" id="vid_px">player_x</field>
                                <value name="AMOUNT"><block type="val_number"><field name="NUM">4</field></block></value>
                              </block>
                            </statement>
                            <next>
                              <block type="pico_if" id="ifl">
                                <value name="IF0">
                                  <block type="game_key_pressed"><field name="KEY">K_LEFT</field></block>
                                </value>
                                <statement name="DO0">
                                  <block type="var_change">
                                    <field name="VAR" id="vid_px">player_x</field>
                                    <value name="AMOUNT"><block type="val_number"><field name="NUM">-4</field></block></value>
                                  </block>
                                </statement>
                                <next>
                                  <block type="pico_if" id="ifu">
                                    <value name="IF0">
                                      <block type="game_key_pressed"><field name="KEY">K_UP</field></block>
                                    </value>
                                    <statement name="DO0">
                                      <block type="var_change">
                                        <field name="VAR" id="vid_py">player_y</field>
                                        <value name="AMOUNT"><block type="val_number"><field name="NUM">-4</field></block></value>
                                      </block>
                                    </statement>
                                    <next>
                                      <block type="pico_if" id="ifd">
                                        <value name="IF0">
                                          <block type="game_key_pressed"><field name="KEY">K_DOWN</field></block>
                                        </value>
                                        <statement name="DO0">
                                          <block type="var_change">
                                            <field name="VAR" id="vid_py">player_y</field>
                                            <value name="AMOUNT"><block type="val_number"><field name="NUM">4</field></block></value>
                                          </block>
                                        </statement>
                                        <next>
                                          <block type="game_draw_rect" id="dr">
                                            <value name="X"><block type="val_var"><field name="VAR" id="vid_px">player_x</field></block></value>
                                            <value name="Y"><block type="val_var"><field name="VAR" id="vid_py">player_y</field></block></value>
                                            <value name="W"><block type="val_number"><field name="NUM">40</field></block></value>
                                            <value name="H"><block type="val_number"><field name="NUM">40</field></block></value>
                                            <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#00bcd4</field></block></value>
                                            <next>
                                              <block type="game_draw_text" id="ht">
                                                <value name="TEXT"><block type="val_str"><field name="TEXT">Move with arrows</field></block></value>
                                                <value name="X"><block type="val_number"><field name="NUM">120</field></block></value>
                                                <value name="Y"><block type="val_number"><field name="NUM">8</field></block></value>
                                                <value name="SIZE"><block type="val_number"><field name="NUM">22</field></block></value>
                                                <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#eeeeee</field></block></value>
                                                <next>
                                                  <block type="game_flip">
                                                    <value name="FPS"><block type="val_number"><field name="NUM">60</field></block></value>
                                                  </block>
                                                </next>
                                              </block>
                                            </next>
                                          </block>
                                        </next>
                                      </block>
                                    </next>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </statement>
                <next>
                  <block type="game_quit"></block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
