<xml xmlns="https://developers.google.com/blockly/xml">
  <!--
    サンプル3: マウスペイント
    確認ポイント: game_mouse_x / game_mouse_y / game_mouse_pressed
    操作: 左クリック=ピンク小円, 右クリック=青大円
    game_fill をループ外に置くことで描いた内容が残る
  -->

  <block type="game_init" x="20" y="20">
    <value name="W"><shadow type="val_number"><field name="NUM">480</field></shadow></value>
    <value name="H"><shadow type="val_number"><field name="NUM">320</field></shadow></value>
    <value name="TITLE"><block type="val_str"><field name="TEXT">ペイント</field></block></value>
    <next>
      <!-- 背景を一度だけ塗る（ループ外） -->
      <block type="game_fill">
        <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#1a1a2e</field></block></value>
        <next>
          <block type="game_loop">
            <statement name="DO">
              <block type="game_events">
                <next>
                  <!-- 左クリック: 小さいピンク円 -->
                  <block type="pico_if">
                    <value name="IF0">
                      <block type="game_mouse_pressed"><field name="BTN">0</field></block>
                    </value>
                    <statement name="DO0">
                      <block type="game_draw_circle">
                        <value name="X"><block type="game_mouse_x"></block></value>
                        <value name="Y"><block type="game_mouse_y"></block></value>
                        <value name="R"><block type="val_number"><field name="NUM">10</field></block></value>
                        <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#ff6699</field></block></value>
                      </block>
                    </statement>
                    <next>
                      <!-- 右クリック: 大きい青円 -->
                      <block type="pico_if">
                        <value name="IF0">
                          <block type="game_mouse_pressed"><field name="BTN">2</field></block>
                        </value>
                        <statement name="DO0">
                          <block type="game_draw_circle">
                            <value name="X"><block type="game_mouse_x"></block></value>
                            <value name="Y"><block type="game_mouse_y"></block></value>
                            <value name="R"><block type="val_number"><field name="NUM">25</field></block></value>
                            <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#44aaff</field></block></value>
                          </block>
                        </statement>
                        <next>
                          <!-- 操作説明テキスト -->
                          <block type="game_draw_text">
                            <value name="TEXT"><block type="val_str"><field name="TEXT">左: 小  右: 大</field></block></value>
                            <value name="X"><block type="val_number"><field name="NUM">10</field></block></value>
                            <value name="Y"><block type="val_number"><field name="NUM">8</field></block></value>
                            <value name="SIZE"><block type="val_number"><field name="NUM">20</field></block></value>
                            <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#888888</field></block></value>
                            <next>
                              <block type="game_flip">
                                <value name="FPS"><block type="val_number"><field name="NUM">60</field></block></value>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </statement>
            <next>
              <block type="game_quit"></block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
