<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vi">i</variable>
  </variables>
  <block type="game_init" x="20" y="20">
    <value name="W"><block type="val_number"><field name="NUM">640</field></block></value>
    <value name="H"><block type="val_number"><field name="NUM">400</field></block></value>
    <value name="TITLE"><block type="val_str"><field name="TEXT">Stripes</field></block></value>
    <next>
      <block type="game_loop">
        <statement name="DO">
          <block type="game_events">
            <next>
              <block type="game_fill">
                <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#ffffff</field></block></value>
                <next>
                  <block type="pico_for_from_to">
                    <field name="VAR" id="vi">i</field>
                    <value name="START"><block type="val_number"><field name="NUM">0</field></block></value>
                    <value name="STOP"><block type="val_number"><field name="NUM">640</field></block></value>
                    <value name="STEP"><block type="val_number"><field name="NUM">80</field></block></value>
                    <statement name="DO">
                      <block type="game_draw_rect">
                        <value name="X"><block type="val_var"><field name="VAR" id="vi">i</field></block></value>
                        <value name="Y"><block type="val_number"><field name="NUM">0</field></block></value>
                        <value name="W"><block type="val_number"><field name="NUM">40</field></block></value>
                        <value name="H"><block type="val_number"><field name="NUM">400</field></block></value>
                        <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#b4d2ff</field></block></value>
                      </block>
                    </statement>
                    <next>
                      <block type="game_flip">
                        <value name="FPS"><block type="val_number"><field name="NUM">60</field></block></value>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </statement>
        <next>
          <block type="game_quit"></block>
        </next>
      </block>
    </next>
  </block>
</xml>
