<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vsy">ship_y</variable>
    <variable id="vsx">ship_x</variable>
  </variables>
  <block type="game_init" x="20" y="20">
    <value name="W"><block type="val_number"><field name="NUM">640</field></block></value>
    <value name="H"><block type="val_number"><field name="NUM">400</field></block></value>
    <value name="TITLE"><block type="val_str"><field name="TEXT">Rising Ship</field></block></value>
    <next>
      <block type="var_set">
        <field name="VAR" id="vsx">ship_x</field>
        <value name="VALUE"><block type="val_number"><field name="NUM">280</field></block></value>
        <next>
          <block type="var_set">
            <field name="VAR" id="vsy">ship_y</field>
            <value name="VALUE"><block type="val_number"><field name="NUM">400</field></block></value>
            <next>
              <block type="game_loop">
                <statement name="DO">
                  <block type="game_events">
                    <next>
                      <block type="game_fill">
                        <value name="COLOR"><block type="colour_picker"><field name="COLOUR">#000030</field></block></value>
                        <next>
                          <block type="var_change">
                            <field name="VAR" id="vsy">ship_y</field>
                            <value name="DELTA"><block type="val_number"><field name="NUM">-2</field></block></value>
                            <next>
                              <block type="pico_if">
                                <value name="IF0">
                                  <block type="cond_compare">
                                    <field name="OP">&lt;</field>
                                    <value name="LEFT"><block type="val_var"><field name="VAR" id="vsy">ship_y</field></block></value>
                                    <value name="RIGHT"><block type="val_number"><field name="NUM">-48</field></block></value>
                                  </block>
                                </value>
                                <statement name="DO0">
                                  <block type="var_set">
                                    <field name="VAR" id="vsy">ship_y</field>
                                    <value name="VALUE"><block type="val_number"><field name="NUM">400</field></block></value>
                                  </block>
                                </statement>
                                <next>
                                  <block type="game_draw_image">
                                    <field name="FLIP">NONE</field>
                                    <value name="URL">
                                      <block type="game_image_preset">
                                        <field name="IMG">assets/game-icons/player_ship.svg</field>
                                      </block>
                                    </value>
                                    <value name="X"><block type="val_var"><field name="VAR" id="vsx">ship_x</field></block></value>
                                    <value name="Y"><block type="val_var"><field name="VAR" id="vsy">ship_y</field></block></value>
                                    <value name="W"><block type="val_number"><field name="NUM">48</field></block></value>
                                    <value name="H"><block type="val_number"><field name="NUM">48</field></block></value>
                                    <value name="ROT"><block type="val_number"><field name="NUM">0</field></block></value>
                                    <next>
                                      <block type="game_flip">
                                        <value name="FPS"><block type="val_number"><field name="NUM">60</field></block></value>
                                      </block>
                                    </next>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </statement>
                <next>
                  <block type="game_quit"></block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
