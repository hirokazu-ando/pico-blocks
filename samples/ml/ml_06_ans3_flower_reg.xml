<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_Xf">X_flower</variable>
    <variable id="var_yf">y_flower</variable>
    <variable id="var_clf">clf</variable>
    <variable id="var_rose_X">rose_X</variable>
    <variable id="var_rose_y">rose_y</variable>
    <variable id="var_reg">reg</variable>
    <variable id="var_pred">pred</variable>
  </variables>
  <block type="ml_import" id="b0" x="30" y="30">
    <next>
      <block type="var_set" id="b1">
        <field name="VAR" id="var_Xf">X_flower</field>
        <value name="VALUE">
          <block type="py_custom_expr" id="bxf"><field name="CODE">[[3,1],[3,2],[4,1],[5,2],[5,3],[6,3],[2,4],[2,5],[1,4]]</field></block>
        </value>
        <next>
          <block type="var_set" id="b2">
            <field name="VAR" id="var_yf">y_flower</field>
            <value name="VALUE">
              <block type="py_custom_expr" id="byf"><field name="CODE">['Rose','Rose','Rose','Rose','Rose','Lily','Lily','Lily','Lily']</field></block>
            </value>
            <next>
              <block type="ml_knn" id="b3">
                <field name="VAR" id="var_clf">clf</field>
                <field name="K">3</field>
                <next>
                  <block type="ml_fit" id="b4">
                    <value name="MODEL"><block type="val_var" id="bv1"><field name="VAR" id="var_clf">clf</field></block></value>
                    <value name="X_TRAIN"><block type="val_var" id="bv2"><field name="VAR" id="var_Xf">X_flower</field></block></value>
                    <value name="Y_TRAIN"><block type="val_var" id="bv3"><field name="VAR" id="var_yf">y_flower</field></block></value>
                    <next>
                      <block type="var_set" id="b5">
                        <field name="VAR" id="var_rose_X">rose_X</field>
                        <value name="VALUE">
                          <block type="py_custom_expr" id="brx"><field name="CODE">[[x[0]] for x, lbl in zip(X_flower, y_flower) if lbl == 'Rose']</field></block>
                        </value>
                        <next>
                          <block type="var_set" id="b6">
                            <field name="VAR" id="var_rose_y">rose_y</field>
                            <value name="VALUE">
                              <block type="py_custom_expr" id="bry"><field name="CODE">[5, 6, 7, 8, 10]</field></block>
                            </value>
                            <next>
                              <block type="ml_linreg" id="b7">
                                <field name="VAR" id="var_reg">reg</field>
                                <next>
                                  <block type="ml_fit" id="b8">
                                    <value name="MODEL"><block type="val_var" id="bv4"><field name="VAR" id="var_reg">reg</field></block></value>
                                    <value name="X_TRAIN"><block type="val_var" id="bv5"><field name="VAR" id="var_rose_X">rose_X</field></block></value>
                                    <value name="Y_TRAIN"><block type="val_var" id="bv6"><field name="VAR" id="var_rose_y">rose_y</field></block></value>
                                    <next>
                                      <block type="ml_predict_stmt" id="b9">
                                        <field name="VAR" id="var_pred">pred</field>
                                        <value name="MODEL"><block type="val_var" id="bv7"><field name="VAR" id="var_reg">reg</field></block></value>
                                        <value name="X_TEST">
                                          <block type="py_custom_expr" id="bte"><field name="CODE">[[7]]</field></block>
                                        </value>
                                        <next>
                                          <block type="py_print" id="b10">
                                            <value name="VALUE"><block type="val_var" id="bv8"><field name="VAR" id="var_pred">pred</field></block></value>
                                          </block>
                                        </next>
                                      </block>
                                    </next>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
