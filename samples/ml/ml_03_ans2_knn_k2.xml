<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_clf">clf</variable>
    <variable id="var_X_tr">X_tr</variable>
    <variable id="var_X_te">X_te</variable>
    <variable id="var_y_tr">y_tr</variable>
    <variable id="var_y_te">y_te</variable>
    <variable id="var_pred">pred</variable>
  </variables>
  <block type="ml_import" id="b0" x="30" y="30">
    <next>
      <block type="ml_split" id="b1">
        <field name="X_TR" id="var_X_tr">X_tr</field>
        <field name="X_TE" id="var_X_te">X_te</field>
        <field name="Y_TR" id="var_y_tr">y_tr</field>
        <field name="Y_TE" id="var_y_te">y_te</field>
        <value name="X"><block type="ml_data_2d"><field name="DATA">[[1,1],[1,2],[2,3],[3,1],[3,2],[4,3]]</field></block></value>
        <value name="Y"><block type="ml_label_list"><field name="DATA">['A','A','B','A','B','B']</field></block></value>
        <field name="RATIO">0.3</field>
        <next>
          <block type="ml_knn" id="b2">
            <field name="VAR" id="var_clf">clf</field>
            <field name="K">2</field>
            <next>
              <block type="ml_fit" id="b3">
                <value name="MODEL"><block type="val_var" id="bv1"><field name="VAR" id="var_clf">clf</field></block></value>
                <value name="X_TRAIN"><block type="val_var" id="bv2"><field name="VAR" id="var_X_tr">X_tr</field></block></value>
                <value name="Y_TRAIN"><block type="val_var" id="bv3"><field name="VAR" id="var_y_tr">y_tr</field></block></value>
                <next>
                  <block type="ml_predict_stmt" id="b4">
                    <field name="VAR" id="var_pred">pred</field>
                    <value name="MODEL"><block type="val_var" id="bv4"><field name="VAR" id="var_clf">clf</field></block></value>
                    <value name="X_TEST"><block type="val_var" id="bv5"><field name="VAR" id="var_X_te">X_te</field></block></value>
                    <next>
                      <block type="py_print" id="b5">
                        <value name="VALUE"><block type="val_var" id="bv6"><field name="VAR" id="var_pred">pred</field></block></value>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
