<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_total">total</variable>
    <variable id="var_min">minutes</variable>
    <variable id="var_sec">seconds</variable>
  </variables>
  <block type="var_set" id="b0" x="30" y="30">
    <field name="VAR" id="var_total">total</field>
    <value name="VALUE"><block type="val_number" id="n0"><field name="NUM">137</field></block></value>
    <next>
      <block type="var_set" id="b1">
        <field name="VAR" id="var_min">minutes</field>
        <value name="VALUE">
          <block type="py_math_op" id="bm1">
            <field name="OP">//</field>
            <value name="LEFT"><block type="val_var" id="bv1"><field name="VAR" id="var_total">total</field></block></value>
            <value name="RIGHT"><block type="val_number" id="n1"><field name="NUM">60</field></block></value>
          </block>
        </value>
        <next>
          <block type="var_set" id="b2">
            <field name="VAR" id="var_sec">seconds</field>
            <value name="VALUE">
              <block type="py_math_op" id="bm2">
                <field name="OP">%</field>
                <value name="LEFT"><block type="val_var" id="bv2"><field name="VAR" id="var_total">total</field></block></value>
                <value name="RIGHT"><block type="val_number" id="n2"><field name="NUM">60</field></block></value>
              </block>
            </value>
            <next>
              <block type="py_custom_stmt" id="cs1">
                <field name="CODE">print(f"{total}秒 = {minutes}分{seconds}秒")</field>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
