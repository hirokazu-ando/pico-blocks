<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_nums">nums</variable>
    <variable id="var_clipped">clipped</variable>
    <variable id="var_labels">labels</variable>
  </variables>
  <block type="var_set" x="30" y="30">
    <field name="VAR" id="var_nums">nums</field>
    <value name="VALUE">
      <block type="py_list_literal">
        <mutation items="6"/>
        <value name="ITEM0"><block type="val_number"><field name="NUM">1</field></block></value>
        <value name="ITEM1"><block type="val_number"><field name="NUM">-3</field></block></value>
        <value name="ITEM2"><block type="val_number"><field name="NUM">5</field></block></value>
        <value name="ITEM3"><block type="val_number"><field name="NUM">-2</field></block></value>
        <value name="ITEM4"><block type="val_number"><field name="NUM">8</field></block></value>
        <value name="ITEM5"><block type="val_number"><field name="NUM">-1</field></block></value>
      </block>
    </value>
    <next>
      <block type="var_set">
        <field name="VAR" id="var_clipped">clipped</field>
        <value name="VALUE">
          <block type="py_custom_expr">
            <field name="CODE">[n if n &gt;= 0 else 0 for n in nums]</field>
          </block>
        </value>
        <next>
          <block type="py_print">
            <value name="VALUE"><block type="val_var"><field name="VAR" id="var_clipped">clipped</field></block></value>
            <next>
              <block type="var_set">
                <field name="VAR" id="var_labels">labels</field>
                <value name="VALUE">
                  <block type="py_custom_expr">
                    <field name="CODE">["偶" if n % 2 == 0 else "奇" for n in range(1, 7)]</field>
                  </block>
                </value>
                <next>
                  <block type="py_print">
                    <value name="VALUE"><block type="val_var"><field name="VAR" id="var_labels">labels</field></block></value>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
