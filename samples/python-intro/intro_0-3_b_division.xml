<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_total">total</variable>
    <variable id="var_people">people</variable>
  </variables>
  <block type="var_set" id="b1" x="30" y="30">
    <field name="VAR" id="var_total">total</field>
    <value name="VALUE">
      <block type="val_number" id="b2">
        <field name="NUM">10</field>
      </block>
    </value>
    <next>
      <block type="var_set" id="b3">
        <field name="VAR" id="var_people">people</field>
        <value name="VALUE">
          <block type="val_number" id="b4">
            <field name="NUM">3</field>
          </block>
        </value>
        <next>
          <block type="py_print" id="b5">
            <value name="VALUE">
              <block type="py_math_op" id="b6">
                <value name="LEFT">
                  <block type="val_var" id="b7">
                    <field name="VAR" id="var_total">total</field>
                  </block>
                </value>
                <field name="OP">//</field>
                <value name="RIGHT">
                  <block type="val_var" id="b8">
                    <field name="VAR" id="var_people">people</field>
                  </block>
                </value>
              </block>
            </value>
            <next>
              <block type="py_print" id="b9">
                <value name="VALUE">
                  <block type="py_math_op" id="b10">
                    <value name="LEFT">
                      <block type="val_var" id="b11">
                        <field name="VAR" id="var_total">total</field>
                      </block>
                    </value>
                    <field name="OP">%</field>
                    <value name="RIGHT">
                      <block type="val_var" id="b12">
                        <field name="VAR" id="var_people">people</field>
                      </block>
                    </value>
                  </block>
                </value>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
