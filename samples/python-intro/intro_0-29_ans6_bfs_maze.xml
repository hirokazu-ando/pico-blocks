  <block type="py_custom_stmt"><field name="CODE">from collections import deque</field><next><block type="py_custom_stmt"><field name="CODE">def bfs_maze(maze, start, goal):</field><next><block type="py_custom_stmt"><field name="CODE">    rows, cols = len(maze), len(maze[0])</field><next><block type="py_custom_stmt"><field name="CODE">    queue = deque([(start, 0)])</field><next><block type="py_custom_stmt"><field name="CODE">    visited = {start}</field><next><block type="py_custom_stmt"><field name="CODE">    while queue:</field><next><block type="py_custom_stmt"><field name="CODE">        (r, c), steps = queue.popleft()</field><next><block type="py_custom_stmt"><field name="CODE">        if (r, c) == goal: return steps</field><next><block type="py_custom_stmt"><field name="CODE">        for dr, dc in [(-1,0),(1,0),(0,-1),(0,1)]:</field><next><block type="py_custom_stmt"><field name="CODE">            nr, nc = r + dr, c + dc</field><next><block type="py_custom_stmt"><field name="CODE">            if 0 &lt;= nr &lt; rows and 0 &lt;= nc &lt; cols:</field><next><block type="py_custom_stmt"><field name="CODE">                if maze[nr][nc] == 0 and (nr,nc) not in visited:</field><next><block type="py_custom_stmt"><field name="CODE">                    visited.add((nr,nc))</field><next><block type="py_custom_stmt"><field name="CODE">                    queue.append(((nr,nc), steps+1))</field><next><block type="py_custom_stmt"><field name="CODE">maze = [[0,0,1,0],[1,0,1,0],[1,0,0,0],[1,1,0,0]]</field><next><block type="py_custom_stmt"><field name="CODE">print(bfs_maze(maze, (0,0), (3,3)))   # 7</field></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block>
