<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_point">point</variable>
    <variable id="var_color">color</variable>
  </variables>
  <block type="var_set" x="30" y="30">
    <field name="VAR" id="var_point">point</field>
    <value name="VALUE">
      <block type="py_tuple_literal">
        <mutation items="2"/>
        <field name="COUNT">2</field>
        <value name="ITEM0"><block type="val_number"><field name="NUM">3</field></block></value>
        <value name="ITEM1"><block type="val_number"><field name="NUM">7</field></block></value>
      </block>
    </value>
    <next>
      <block type="var_set">
        <field name="VAR" id="var_color">color</field>
        <value name="VALUE">
          <block type="py_tuple_literal">
            <mutation items="3"/>
            <field name="COUNT">3</field>
            <value name="ITEM0"><block type="val_number"><field name="NUM">255</field></block></value>
            <value name="ITEM1"><block type="val_number"><field name="NUM">128</field></block></value>
            <value name="ITEM2"><block type="val_number"><field name="NUM">0</field></block></value>
          </block>
        </value>
        <next>
          <block type="py_print">
            <value name="VALUE">
              <block type="py_custom_expr">
                <field name="CODE">point[0]</field>
              </block>
            </value>
            <next>
              <block type="py_print">
                <value name="VALUE">
                  <block type="py_custom_expr">
                    <field name="CODE">color[1]</field>
                  </block>
                </value>
                <next>
                  <block type="py_custom_stmt">
                    <field name="CODE">x, y = point</field>
                    <next>
                      <block type="py_custom_stmt">
                        <field name="CODE">print(x, y)</field>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
