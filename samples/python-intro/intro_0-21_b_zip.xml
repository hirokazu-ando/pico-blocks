<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_names">names</variable>
    <variable id="var_scores">scores</variable>
    <variable id="var_name">name</variable>
    <variable id="var_score">score</variable>
  </variables>
  <block type="py_zip_for" x="30" y="30">
    <field name="VAR_A" id="var_name">name</field>
    <field name="VAR_B" id="var_score">score</field>
    <field name="LIST_A" id="var_names">names</field>
    <field name="LIST_B" id="var_scores">scores</field>
    <statement name="DO">
      <block type="py_print">
        <value name="VALUE">
          <block type="py_custom_expr">
            <field name="CODE">f"{name}: {score}点"</field>
          </block>
        </value>
      </block>
    </statement>
  </block>
</xml>
