<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_kok">kokugo</variable>
    <variable id="var_mat">math</variable>
    <variable id="var_eng">english</variable>
    <variable id="var_rik">rika</variable>
    <variable id="var_sha">shakai</variable>
    <variable id="var_tot">total</variable>
    <variable id="var_avg">average</variable>
  </variables>
  <block type="var_set" id="b0" x="30" y="30">
    <field name="VAR" id="var_kok">kokugo</field>
    <value name="VALUE"><block type="val_number" id="n1"><field name="NUM">85</field></block></value>
    <next>
      <block type="var_set" id="b1">
        <field name="VAR" id="var_mat">math</field>
        <value name="VALUE"><block type="val_number" id="n2"><field name="NUM">72</field></block></value>
        <next>
          <block type="var_set" id="b2">
            <field name="VAR" id="var_eng">english</field>
            <value name="VALUE"><block type="val_number" id="n3"><field name="NUM">90</field></block></value>
            <next>
              <block type="var_set" id="b3">
                <field name="VAR" id="var_rik">rika</field>
                <value name="VALUE"><block type="val_number" id="n4"><field name="NUM">68</field></block></value>
                <next>
                  <block type="var_set" id="b4">
                    <field name="VAR" id="var_sha">shakai</field>
                    <value name="VALUE"><block type="val_number" id="n5"><field name="NUM">78</field></block></value>
                    <next>
                      <block type="var_set" id="b5">
                        <field name="VAR" id="var_tot">total</field>
                        <value name="VALUE">
                          <block type="py_custom_expr" id="bce">
                            <field name="CODE">kokugo + math + english + rika + shakai</field>
                          </block>
                        </value>
                        <next>
                          <block type="var_set" id="b6">
                            <field name="VAR" id="var_avg">average</field>
                            <value name="VALUE">
                              <block type="py_math_op" id="bm">
                                <field name="OP">/</field>
                                <value name="LEFT"><block type="val_var" id="bvt"><field name="VAR" id="var_tot">total</field></block></value>
                                <value name="RIGHT"><block type="val_number" id="n6"><field name="NUM">5</field></block></value>
                              </block>
                            </value>
                            <next>
                              <block type="py_custom_stmt" id="cs1">
                                <field name="CODE">print(f"合計: {total}点")</field>
                                <next>
                                  <block type="py_custom_stmt" id="cs2">
                                    <field name="CODE">print(f"平均: {average:.1f}点")</field>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
