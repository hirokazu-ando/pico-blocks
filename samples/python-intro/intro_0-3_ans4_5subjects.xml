<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_kok">kokugo</variable>
    <variable id="var_mat">math</variable>
    <variable id="var_eng">english</variable>
    <variable id="var_rik">rika</variable>
    <variable id="var_sha">shakai</variable>
    <variable id="var_tot">total</variable>
    <variable id="var_avg">average</variable>
  </variables>
  <block type="var_set" id="b0" x="30" y="30">
    <field name="VAR" id="var_kok">kokugo</field>
    <value name="VALUE"><block type="val_number" id="n1"><field name="NUM">85</field></block></value>
    <next>
      <block type="var_set" id="b1">
        <field name="VAR" id="var_mat">math</field>
        <value name="VALUE"><block type="val_number" id="n2"><field name="NUM">72</field></block></value>
        <next>
          <block type="var_set" id="b2">
            <field name="VAR" id="var_eng">english</field>
            <value name="VALUE"><block type="val_number" id="n3"><field name="NUM">90</field></block></value>
            <next>
              <block type="var_set" id="b3">
                <field name="VAR" id="var_rik">rika</field>
                <value name="VALUE"><block type="val_number" id="n4"><field name="NUM">68</field></block></value>
                <next>
                  <block type="var_set" id="b4">
                    <field name="VAR" id="var_sha">shakai</field>
                    <value name="VALUE"><block type="val_number" id="n5"><field name="NUM">78</field></block></value>
                    <next>
                      <block type="var_set" id="b5">
                        <field name="VAR" id="var_tot">total</field>
                        <value name="VALUE">
                          <block type="py_math_op" id="bm4">
                            <field name="OP">+</field>
                            <value name="LEFT">
                              <block type="py_math_op" id="bm3">
                                <field name="OP">+</field>
                                <value name="LEFT">
                                  <block type="py_math_op" id="bm2">
                                    <field name="OP">+</field>
                                    <value name="LEFT">
                                      <block type="py_math_op" id="bm1">
                                        <field name="OP">+</field>
                                        <value name="LEFT"><block type="val_var" id="bv1"><field name="VAR" id="var_kok">kokugo</field></block></value>
                                        <value name="RIGHT"><block type="val_var" id="bv2"><field name="VAR" id="var_mat">math</field></block></value>
                                      </block>
                                    </value>
                                    <value name="RIGHT"><block type="val_var" id="bv3"><field name="VAR" id="var_eng">english</field></block></value>
                                  </block>
                                </value>
                                <value name="RIGHT"><block type="val_var" id="bv4"><field name="VAR" id="var_rik">rika</field></block></value>
                              </block>
                            </value>
                            <value name="RIGHT"><block type="val_var" id="bv5"><field name="VAR" id="var_sha">shakai</field></block></value>
                          </block>
                        </value>
                        <next>
                          <block type="var_set" id="b6">
                            <field name="VAR" id="var_avg">average</field>
                            <value name="VALUE">
                              <block type="py_math_op" id="bm5">
                                <field name="OP">/</field>
                                <value name="LEFT"><block type="val_var" id="bvt"><field name="VAR" id="var_tot">total</field></block></value>
                                <value name="RIGHT"><block type="val_number" id="n6"><field name="NUM">5</field></block></value>
                              </block>
                            </value>
                            <next>
                              <block type="py_print" id="bp1">
                                <value name="VALUE">
                                  <block type="py_fstring" id="bfs1">
                                    <field name="PRE">合計: </field>
                                    <field name="POST">点</field>
                                    <value name="VAR"><block type="val_var" id="bvtot"><field name="VAR" id="var_tot">total</field></block></value>
                                  </block>
                                </value>
                                <next>
                                  <block type="py_print" id="bp2">
                                    <value name="VALUE">
                                      <block type="py_str_concat" id="bsc">
                                        <value name="A">
                                          <block type="py_fstring_fmt" id="bff">
                                            <field name="PRE">平均: </field>
                                            <field name="FMT">.1f</field>
                                            <value name="VAR"><block type="val_var" id="bvavg"><field name="VAR" id="var_avg">average</field></block></value>
                                          </block>
                                        </value>
                                        <value name="B"><block type="val_str" id="vs2"><field name="TEXT">点</field></block></value>
                                      </block>
                                    </value>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
