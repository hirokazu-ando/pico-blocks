  <block type="var_set"><field name="VAR" id="vd">data</field><value name="VALUE"><block type="py_custom_expr"><field name="CODE">[6, 2, 9, 4, 1]</field></block></value><next><block type="var_set"><field name="VAR" id="vn">n</field><value name="VALUE"><block type="py_custom_expr"><field name="CODE">len(data)</field></block></value><next><block type="py_custom_stmt"><field name="CODE">for i in range(1, n):</field><next><block type="py_custom_stmt"><field name="CODE">    key = data[i]</field><next><block type="py_custom_stmt"><field name="CODE">    j = i - 1</field><next><block type="py_custom_stmt"><field name="CODE">    while j &gt;= 0 and data[j] &gt; key:</field><next><block type="py_custom_stmt"><field name="CODE">        data[j + 1] = data[j]</field><next><block type="py_custom_stmt"><field name="CODE">        j -= 1</field><next><block type="py_custom_stmt"><field name="CODE">    data[j + 1] = key</field><next><block type="py_custom_stmt"><field name="CODE">    print(f"ステップ{i}: {data}")</field></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block>
