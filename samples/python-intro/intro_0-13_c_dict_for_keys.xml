<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables><variable id="var_scores">scores</variable><variable id="var_keys">keys</variable><variable id="var_name">name</variable></variables>
  <block type="var_set" id="b1" x="30" y="30">
    <field name="VAR" id="var_scores">scores</field>
    <value name="VALUE"><block type="py_custom_expr" id="b2"><field name="CODE">{"math": 80, "science": 90}</field></block></value>
    <next>
      <block type="var_set" id="b3">
        <field name="VAR" id="var_keys">keys</field>
        <value name="VALUE"><block type="py_dict_keys" id="b4"><field name="DICT" id="var_scores">scores</field></block></value>
        <next>
          <block type="py_for_list" id="b5">
            <field name="VAR" id="var_name">name</field>
            <field name="LIST" id="var_keys">keys</field>
            <statement name="DO">
              <block type="py_print" id="b6">
                <value name="VALUE">
                  <block type="py_dict_get" id="b7">
                    <field name="DICT" id="var_scores">scores</field>
                    <value name="KEY"><block type="val_var" id="b8"><field name="VAR" id="var_name">name</field></block></value>
                  </block>
                </value>
              </block>
            </statement>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
