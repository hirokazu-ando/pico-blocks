    <variable id="var_n">n</variable>
    <variable id="var_i">i</variable>
    <variable id="var_j">j</variable>
  </variables>
  <block type="py_def" x="30" y="30">
    <field name="NAME">bubble_sort</field>
    <field name="PARAM" id="var_data">data</field>
    <statement name="BODY">
      <block type="var_set">
        <field name="VAR" id="var_n">n</field>
        <value name="VALUE"><block type="py_list_len"><field name="LIST" id="var_data">data</field></block></value>
        <next>
          <block type="controls_for">
            <field name="VAR" id="var_i">i</field>
            <value name="FROM"><block type="val_number"><field name="NUM">0</field></block></value>
            <value name="TO">
              <block type="py_math_op">
                <field name="OP">-</field>
                <value name="LEFT"><block type="val_var"><field name="VAR" id="var_n">n</field></block></value>
                <value name="RIGHT"><block type="val_number"><field name="NUM">2</field></block></value>
              </block>
            </value>
            <value name="BY"><block type="val_number"><field name="NUM">1</field></block></value>
            <statement name="DO">
              <block type="controls_for">
                <field name="VAR" id="var_j">j</field>
                <value name="FROM"><block type="val_number"><field name="NUM">0</field></block></value>
                <value name="TO">
                  <block type="py_math_op">
                    <field name="OP">-</field>
                    <value name="LEFT"><block type="val_var"><field name="VAR" id="var_n">n</field></block></value>
                    <value name="RIGHT">
                      <block type="py_math_op">
                        <field name="OP">+</field>
                        <value name="LEFT"><block type="val_var"><field name="VAR" id="var_i">i</field></block></value>
                        <value name="RIGHT"><block type="val_number"><field name="NUM">2</field></block></value>
                      </block>
                    </value>
                  </block>
                </value>
                <value name="BY"><block type="val_number"><field name="NUM">1</field></block></value>
                <statement name="DO">
                  <block type="controls_if">
                    <value name="IF0">
                      <block type="cond_compare">
                        <field name="OP">&gt;</field>
                        <value name="LEFT">
                          <block type="py_list_get">
                            <field name="LIST" id="var_data">data</field>
                            <value name="INDEX"><block type="val_var"><field name="VAR" id="var_j">j</field></block></value>
                          </block>
                        </value>
                        <value name="RIGHT">
                          <block type="py_list_get">
                            <field name="LIST" id="var_data">data</field>
                            <value name="INDEX">
                              <block type="py_math_op">
                                <field name="OP">+</field>
                                <value name="LEFT"><block type="val_var"><field name="VAR" id="var_j">j</field></block></value>
                                <value name="RIGHT"><block type="val_number"><field name="NUM">1</field></block></value>
                              </block>
                            </value>
                          </block>
                        </value>
                      </block>
                    </value>
                    <statement name="DO0">
                      <block type="py_custom_stmt">
                        <field name="CODE">data[j], data[j+1] = data[j+1], data[j]</field>
                      </block>
                    </statement>
                  </block>
                </statement>
              </block>
            </statement>
          </block>
        </next>
      </block>
    </statement>
  </block>
