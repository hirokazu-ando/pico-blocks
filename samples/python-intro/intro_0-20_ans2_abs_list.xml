<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vn">nums</variable>
    <variable id="va">abs_nums</variable>
    <variable id="vi">n</variable>
  </variables>
  <block type="var_set" x="30" y="30">
    <field name="VAR" id="vn">nums</field>
    <value name="VALUE">
      <block type="py_list_literal">
        <mutation items="8"/>
        <value name="ITEM0"><block type="val_number"><field name="NUM">-3</field></block></value>
        <value name="ITEM1"><block type="val_number"><field name="NUM">1</field></block></value>
        <value name="ITEM2"><block type="val_number"><field name="NUM">-4</field></block></value>
