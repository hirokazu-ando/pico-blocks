<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_scores">scores</variable>
    <variable id="var_score">score</variable>
    <variable id="var_total">total</variable>
  </variables>
  <block type="py_def" id="b1" x="30" y="30">
    <field name="NAME">average</field>
    <field name="PARAM" id="var_scores">scores</field>
    <statement name="BODY">
      <block type="var_set" id="b2">
        <field name="VAR" id="var_total">total</field>
        <value name="VALUE"><block type="val_number" id="b3"><field name="NUM">0</field></block></value>
        <next>
          <block type="py_for_list" id="b4">
            <field name="VAR" id="var_score">score</field>
            <field name="LIST" id="var_scores">scores</field>
            <statement name="DO">
              <block type="var_change" id="b5">
                <field name="VAR" id="var_total">total</field>
                <value name="AMOUNT"><block type="val_var" id="b6"><field name="VAR" id="var_score">score</field></block></value>
              </block>
            </statement>
            <next>
              <block type="py_return" id="b7">
                <value name="VALUE">
                  <block type="py_custom_expr" id="b8"><field name="CODE">total / len(scores)</field></block>
                </value>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
    <next>
      <block type="py_print" id="b9">
        <value name="VALUE">
          <block type="py_call_val" id="b10">
            <field name="NAME">average</field>
            <value name="ARG">
              <block type="py_custom_expr" id="b11"><field name="CODE">[80, 90, 70]</field></block>
            </value>
          </block>
        </value>
      </block>
    </next>
  </block>
</xml>
