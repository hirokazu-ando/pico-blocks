<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables><variable id="var_age">age</variable></variables>
  <block type="py_input" id="b1" x="30" y="30">
    <field name="TYPE">int</field>
    <field name="VAR" id="var_age">age</field>
    <field name="PROMPT">年齢を入力してください</field>
    <next>
      <block type="pico_if" id="b2">
        <mutation elseif="2" else="1"></mutation>
        <value name="IF0">
          <block type="cond_compare" id="b3">
            <field name="OP">&lt;=</field>
            <value name="LEFT"><block type="val_var" id="b4"><field name="VAR" id="var_age">age</field></block></value>
            <value name="RIGHT"><block type="val_number" id="b5"><field name="NUM">12</field></block></value>
          </block>
        </value>
        <statement name="DO0">
          <block type="print_text" id="b6"><field name="TEXT">子供料金: 100円</field></block>
        </statement>
        <value name="IF1">
          <block type="cond_compare" id="b7">
            <field name="OP">&lt;=</field>
            <value name="LEFT"><block type="val_var" id="b8"><field name="VAR" id="var_age">age</field></block></value>
            <value name="RIGHT"><block type="val_number" id="b9"><field name="NUM">17</field></block></value>
          </block>
        </value>
        <statement name="DO1">
          <block type="print_text" id="b10"><field name="TEXT">学生料金: 200円</field></block>
        </statement>
        <value name="IF2">
          <block type="cond_compare" id="b11">
            <field name="OP">&lt;=</field>
            <value name="LEFT"><block type="val_var" id="b12"><field name="VAR" id="var_age">age</field></block></value>
            <value name="RIGHT"><block type="val_number" id="b13"><field name="NUM">64</field></block></value>
          </block>
        </value>
        <statement name="DO2">
          <block type="print_text" id="b14"><field name="TEXT">大人料金: 500円</field></block>
        </statement>
        <statement name="ELSE">
          <block type="print_text" id="b15"><field name="TEXT">シニア料金: 300円</field></block>
        </statement>
      </block>
    </next>
  </block>
</xml>
