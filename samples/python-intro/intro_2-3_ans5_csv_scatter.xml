<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_rows">rows</variable>
    <variable id="var_temp">temp</variable>
    <variable id="var_rain">rain</variable>
  </variables>
  <block type="py_import_csv" id="b1" x="30" y="30">
    <next>
      <block type="py_import_plt" id="b2">
        <next>
          <block type="py_csv_read_rows" id="b3">
            <field name="VAR" id="var_rows">rows</field>
            <field name="FILENAME">data.csv</field>
            <next>
              <block type="py_csv_get_col" id="b4">
                <field name="VAR" id="var_temp">temp</field>
                <field name="ROWS" id="var_rows">rows</field>
                <field name="COL">1</field>
                <next>
                  <block type="py_csv_get_col" id="b5">
                    <field name="VAR" id="var_rain">rain</field>
                    <field name="ROWS" id="var_rows">rows</field>
                    <field name="COL">2</field>
                    <next>
                      <block type="py_plt_scatter" id="b6">
                        <value name="X"><block type="val_var"><field name="VAR" id="var_temp">temp</field></block></value>
                        <value name="Y"><block type="val_var"><field name="VAR" id="var_rain">rain</field></block></value>
                        <next>
                          <block type="py_plt_title" id="b7">
                            <value name="TEXT"><block type="val_str"><field name="TEXT">気温と雨量の関係</field></block></value>
                            <next>
                              <block type="py_plt_xlabel" id="b8">
                                <value name="TEXT"><block type="val_str"><field name="TEXT">気温(℃)</field></block></value>
                                <next>
                                  <block type="py_plt_ylabel" id="b9">
                                    <value name="TEXT"><block type="val_str"><field name="TEXT">雨量(mm)</field></block></value>
                                    <next>
                                      <block type="py_plt_show" id="b10"></block>
                                    </next>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
