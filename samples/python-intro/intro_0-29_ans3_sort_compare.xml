      <block type="py_custom_stmt">
        <field name="CODE">def bubble_sort(data):        # 隣同士を比較・交換、安定、O(n²)</field>
        <next><block type="py_custom_stmt"><field name="CODE">    data = data[:]</field>
        <next><block type="py_custom_stmt"><field name="CODE">    n = len(data)</field>
        <next><block type="py_custom_stmt"><field name="CODE">    for i in range(n - 1):</field>
        <next><block type="py_custom_stmt"><field name="CODE">        for j in range(n - i - 1):</field>
        <next><block type="py_custom_stmt"><field name="CODE">            if data[j] &gt; data[j + 1]:</field>
        <next><block type="py_custom_stmt"><field name="CODE">                data[j], data[j + 1] = data[j + 1], data[j]</field>
        <next><block type="py_custom_stmt"><field name="CODE">    return data</field>
        <next><block type="py_custom_stmt"><field name="CODE">def insertion_sort(data):     # カード挿入方式、安定、O(n²)</field>
        <next><block type="py_custom_stmt"><field name="CODE">    data = data[:]</field>
        <next><block type="py_custom_stmt"><field name="CODE">    n = len(data)</field>
        <next><block type="py_custom_stmt"><field name="CODE">    for i in range(1, n):</field>
        <next><block type="py_custom_stmt"><field name="CODE">        key = data[i]</field>
        <next><block type="py_custom_stmt"><field name="CODE">        j = i - 1</field>
        <next><block type="py_custom_stmt"><field name="CODE">        while j &gt;= 0 and data[j] &gt; key:</field>
        <next><block type="py_custom_stmt"><field name="CODE">            data[j + 1] = data[j]</field>
        <next><block type="py_custom_stmt"><field name="CODE">            j -= 1</field>
        <next><block type="py_custom_stmt"><field name="CODE">        data[j + 1] = key</field>
        <next><block type="py_custom_stmt"><field name="CODE">    return data</field>
        <next><block type="py_custom_stmt"><field name="CODE">def selection_sort(data):     # 最小値を選んで前へ、不安定、O(n²)</field>
        <next><block type="py_custom_stmt"><field name="CODE">    data = data[:]</field>
        <next><block type="py_custom_stmt"><field name="CODE">    n = len(data)</field>
        <next><block type="py_custom_stmt"><field name="CODE">    for i in range(n - 1):</field>
        <next><block type="py_custom_stmt"><field name="CODE">        min_idx = i</field>
        <next><block type="py_custom_stmt"><field name="CODE">        for j in range(i + 1, n):</field>
        <next><block type="py_custom_stmt"><field name="CODE">            if data[j] &lt; data[min_idx]:</field>
        <next><block type="py_custom_stmt"><field name="CODE">                min_idx = j</field>
        <next><block type="py_custom_stmt"><field name="CODE">        data[i], data[min_idx] = data[min_idx], data[i]</field>
        <next><block type="py_custom_stmt"><field name="CODE">    return data</field>
