<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_temp">temp</variable>
    <variable id="var_months">months</variable>
  </variables>
  <block type="py_import_plt" id="b0" x="30" y="30">
    <next>
      <block type="var_set" id="b1">
        <field name="VAR" id="var_months">months</field>
        <value name="VALUE">
          <block type="py_list_literal">
            <mutation items="6"/>
            <value name="ITEM0"><block type="val_str"><field name="TEXT">1月</field></block></value>
            <value name="ITEM1"><block type="val_str"><field name="TEXT">2月</field></block></value>
            <value name="ITEM2"><block type="val_str"><field name="TEXT">3月</field></block></value>
            <value name="ITEM3"><block type="val_str"><field name="TEXT">4月</field></block></value>
            <value name="ITEM4"><block type="val_str"><field name="TEXT">5月</field></block></value>
            <value name="ITEM5"><block type="val_str"><field name="TEXT">6月</field></block></value>
          </block>
        </value>
        <next>
          <block type="var_set" id="b2">
            <field name="VAR" id="var_temp">temp</field>
            <value name="VALUE">
              <block type="py_list_literal">
                <mutation items="6"/>
                <value name="ITEM0"><block type="val_number"><field name="NUM">18</field></block></value>
                <value name="ITEM1"><block type="val_number"><field name="NUM">20</field></block></value>
                <value name="ITEM2"><block type="val_number"><field name="NUM">25</field></block></value>
                <value name="ITEM3"><block type="val_number"><field name="NUM">28</field></block></value>
                <value name="ITEM4"><block type="val_number"><field name="NUM">30</field></block></value>
                <value name="ITEM5"><block type="val_number"><field name="NUM">27</field></block></value>
              </block>
            </value>
            <next>
              <block type="py_plt_plot" id="b3">
                <value name="X"><block type="val_var"><field name="VAR" id="var_months">months</field></block></value>
                <value name="Y"><block type="val_var"><field name="VAR" id="var_temp">temp</field></block></value>
                <next>
                  <block type="py_plt_title" id="b4">
                    <value name="TEXT"><block type="val_str"><field name="TEXT">月別気温（折れ線）</field></block></value>
                    <next>
                      <block type="py_plt_xlabel" id="b4x">
                        <value name="TEXT"><block type="val_str"><field name="TEXT">月</field></block></value>
                        <next>
                          <block type="py_plt_ylabel" id="b5">
                            <value name="TEXT"><block type="val_str"><field name="TEXT">気温(℃)</field></block></value>
                            <next>
                              <block type="py_plt_show" id="b6">
                                <next>
                                  <block type="py_plt_bar" id="b7">
                                    <value name="X"><block type="val_var"><field name="VAR" id="var_months">months</field></block></value>
                                    <value name="Y"><block type="val_var"><field name="VAR" id="var_temp">temp</field></block></value>
                                    <next>
                                      <block type="py_plt_title" id="b8">
                                        <value name="TEXT"><block type="val_str"><field name="TEXT">月別気温（棒グラフ）</field></block></value>
                                        <next>
                                          <block type="py_plt_xlabel" id="b8x">
                                            <value name="TEXT"><block type="val_str"><field name="TEXT">月</field></block></value>
                                            <next>
                                              <block type="py_plt_ylabel" id="b9">
                                                <value name="TEXT"><block type="val_str"><field name="TEXT">気温(℃)</field></block></value>
                                                <next>
                                                  <block type="py_plt_show" id="b10"></block>
                                                </next>
                                              </block>
                                            </next>
                                          </block>
                                        </next>
                                      </block>
                                    </next>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
