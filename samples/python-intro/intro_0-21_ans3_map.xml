<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vsn">str_nums</variable>
    <variable id="vin">int_nums</variable>
  </variables>
  <block type="var_set" x="30" y="30">
    <field name="VAR" id="vsn">str_nums</field>
    <value name="VALUE">
      <block type="py_list_literal">
        <mutation items="5"/>
        <value name="ITEM0"><block type="val_str"><field name="TEXT">5</field></block></value>
        <value name="ITEM1"><block type="val_str"><field name="TEXT">3</field></block></value>
        <value name="ITEM2"><block type="val_str"><field name="TEXT">8</field></block></value>
        <value name="ITEM3"><block type="val_str"><field name="TEXT">1</field></block></value>
        <value name="ITEM4"><block type="val_str"><field name="TEXT">9</field></block></value>
      </block>
    </value>
    <next>
      <block type="var_set">
        <field name="VAR" id="vin">int_nums</field>
        <value name="VALUE">
          <block type="py_map_call">
            <field name="LIST" id="vsn">str_nums</field>
            <field name="TYPE">int</field>
          </block>
        </value>
        <next>
          <block type="py_print">
            <value name="VALUE">
              <block type="py_fstring">
                <field name="PRE">合計: </field>
                <value name="VAR"><block type="py_sum_call"><field name="LIST" id="vin">int_nums</field></block></value>
                <field name="POST"></field>
              </block>
            </value>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
