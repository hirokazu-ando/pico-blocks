<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_height">height</variable>
    <variable id="var_weight">weight</variable>
    <variable id="var_bmi">bmi</variable>
  </variables>
  <block type="var_set" id="b1" x="30" y="30">
    <field name="VAR" id="var_height">height</field>
    <value name="VALUE"><block type="val_number" id="b2"><field name="NUM">1.70</field></block></value>
    <next>
      <block type="var_set" id="b3">
        <field name="VAR" id="var_weight">weight</field>
        <value name="VALUE"><block type="val_number" id="b4"><field name="NUM">65</field></block></value>
        <next>
          <block type="var_set" id="b5">
            <field name="VAR" id="var_bmi">bmi</field>
            <value name="VALUE">
              <block type="py_math_op" id="b6">
                <value name="LEFT"><block type="val_var" id="b7"><field name="VAR" id="var_weight">weight</field></block></value>
                <field name="OP">/</field>
                <value name="RIGHT">
                  <block type="py_math_op" id="b8">
                    <value name="LEFT"><block type="val_var" id="b9"><field name="VAR" id="var_height">height</field></block></value>
                    <field name="OP">**</field>
                    <value name="RIGHT"><block type="val_number" id="b10"><field name="NUM">2</field></block></value>
                  </block>
                </value>
              </block>
            </value>
            <next>
              <block type="print_var_label" id="b11">
                <field name="LABEL">BMI: </field>
                <field name="VAR" id="var_bmi">bmi</field>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
