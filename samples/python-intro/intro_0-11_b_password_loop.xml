<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables><variable id="var_password">password</variable></variables>
  <block type="var_set" id="b1" x="30" y="30">
    <field name="VAR" id="var_password">password</field>
    <value name="VALUE"><block type="val_str" id="b2"><field name="TEXT"></field></block></value>
    <next>
      <block type="py_while" id="b3">
        <value name="COND">
          <block type="cond_compare" id="b4">
            <field name="OP">!=</field>
            <value name="LEFT"><block type="val_var" id="b5"><field name="VAR" id="var_password">password</field></block></value>
            <value name="RIGHT"><block type="val_str" id="b6"><field name="TEXT">python</field></block></value>
          </block>
        </value>
        <statement name="DO">
          <block type="py_input" id="b7">
            <field name="TYPE">str</field>
            <field name="VAR" id="var_password">password</field>
            <field name="PROMPT">合言葉は？</field>
          </block>
        </statement>
        <next>
          <block type="print_text" id="b8"><field name="TEXT">OK!</field></block>
        </next>
      </block>
    </next>
  </block>
</xml>
