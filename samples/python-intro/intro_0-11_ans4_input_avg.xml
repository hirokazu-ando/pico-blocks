<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_total">total</variable>
    <variable id="var_count">count</variable>
    <variable id="var_n">n</variable>
  </variables>
  <block type="var_set" id="b0" x="30" y="30">
    <field name="VAR" id="var_total">total</field>
    <value name="VALUE"><block type="val_number" id="n0"><field name="NUM">0</field></block></value>
    <next>
      <block type="var_set" id="b1">
        <field name="VAR" id="var_count">count</field>
        <value name="VALUE"><block type="val_number" id="n1"><field name="NUM">0</field></block></value>
        <next>
          <block type="py_input" id="b2">
            <field name="TYPE">int</field>
            <field name="VAR" id="var_n">n</field>
            <field name="PROMPT">数を入力（0で終了）: </field>
            <next>
              <block type="py_custom_stmt" id="cs1">
                <field name="CODE">while n != 0:</field>
                <next>
                  <block type="py_custom_stmt" id="cs2">
                    <field name="CODE">  total = total + n</field>
                    <next>
                      <block type="py_custom_stmt" id="cs3">
                        <field name="CODE">  count = count + 1</field>
                        <next>
                          <block type="py_custom_stmt" id="cs4">
                            <field name="CODE">  n = int(input("数を入力（0で終了）: "))</field>
                            <next>
                              <block type="py_custom_stmt" id="cs5">
                                <field name="CODE">if count &gt; 0:</field>
                                <next>
                                  <block type="py_custom_stmt" id="cs6">
                                    <field name="CODE">  print("合計:", total, "  個数:", count, "  平均:", total / count)</field>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
