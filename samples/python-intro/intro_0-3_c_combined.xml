<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_s1">score1</variable>
    <variable id="var_s2">score2</variable>
    <variable id="var_s3">score3</variable>
    <variable id="var_total">total</variable>
    <variable id="var_avg">average</variable>
  </variables>
  <block type="var_set" id="b1" x="30" y="30">
    <field name="VAR" id="var_s1">score1</field>
    <value name="VALUE">
      <block type="val_number" id="b2">
        <field name="NUM">85</field>
      </block>
    </value>
    <next>
      <block type="var_set" id="b3">
        <field name="VAR" id="var_s2">score2</field>
        <value name="VALUE">
          <block type="val_number" id="b4">
            <field name="NUM">72</field>
          </block>
        </value>
        <next>
          <block type="var_set" id="b5">
            <field name="VAR" id="var_s3">score3</field>
            <value name="VALUE">
              <block type="val_number" id="b6">
                <field name="NUM">90</field>
              </block>
            </value>
            <next>
              <block type="var_set" id="b7">
                <field name="VAR" id="var_total">total</field>
                <value name="VALUE">
                  <block type="py_math_op" id="b8">
                    <value name="LEFT">
                      <block type="py_math_op" id="b9">
                        <value name="LEFT">
                          <block type="val_var" id="b10">
                            <field name="VAR" id="var_s1">score1</field>
                          </block>
                        </value>
                        <field name="OP">+</field>
                        <value name="RIGHT">
                          <block type="val_var" id="b11">
                            <field name="VAR" id="var_s2">score2</field>
                          </block>
                        </value>
                      </block>
                    </value>
                    <field name="OP">+</field>
                    <value name="RIGHT">
                      <block type="val_var" id="b12">
                        <field name="VAR" id="var_s3">score3</field>
                      </block>
                    </value>
                  </block>
                </value>
                <next>
                  <block type="var_set" id="b13">
                    <field name="VAR" id="var_avg">average</field>
                    <value name="VALUE">
                      <block type="py_math_op" id="b14">
                        <value name="LEFT">
                          <block type="val_var" id="b15">
                            <field name="VAR" id="var_total">total</field>
                          </block>
                        </value>
                        <field name="OP">/</field>
                        <value name="RIGHT">
                          <block type="val_number" id="b16">
                            <field name="NUM">3</field>
                          </block>
                        </value>
                      </block>
                    </value>
                    <next>
                      <block type="print_var_label" id="b17">
                        <field name="LABEL">合計: </field>
                        <field name="VAR" id="var_total">total</field>
                        <next>
                          <block type="print_var_label" id="b18">
                            <field name="LABEL">平均: </field>
                            <field name="VAR" id="var_avg">average</field>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
