<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_height">height</variable>
    <variable id="var_weight">weight</variable>
    <variable id="var_bmi">bmi</variable>
  </variables>
  <block type="py_input" id="b1" x="30" y="30">
    <field name="TYPE">float</field>
    <field name="VAR" id="var_height">height</field>
    <field name="PROMPT">身長（m）を入力してください</field>
    <next>
      <block type="py_input" id="b2">
        <field name="TYPE">float</field>
        <field name="VAR" id="var_weight">weight</field>
        <field name="PROMPT">体重（kg）を入力してください</field>
        <next>
          <block type="var_set" id="b3">
            <field name="VAR" id="var_bmi">bmi</field>
            <value name="VALUE">
              <block type="py_math_op" id="b4">
                <value name="LEFT"><block type="val_var" id="b5"><field name="VAR" id="var_weight">weight</field></block></value>
                <field name="OP">/</field>
                <value name="RIGHT">
                  <block type="py_math_op" id="b6">
                    <value name="LEFT"><block type="val_var" id="b7"><field name="VAR" id="var_height">height</field></block></value>
                    <field name="OP">**</field>
                    <value name="RIGHT"><block type="val_number" id="b8"><field name="NUM">2</field></block></value>
                  </block>
                </value>
              </block>
            </value>
            <next>
              <block type="pico_if" id="b9">
                <mutation elseif="1" else="1"></mutation>
                <value name="IF0">
                  <block type="cond_compare" id="b10">
                    <field name="OP">&lt;</field>
                    <value name="LEFT"><block type="val_var" id="b11"><field name="VAR" id="var_bmi">bmi</field></block></value>
                    <value name="RIGHT"><block type="val_number" id="b12"><field name="NUM">18.5</field></block></value>
                  </block>
                </value>
                <statement name="DO0">
                  <block type="print_text" id="b13"><field name="TEXT">低体重</field></block>
                </statement>
                <value name="IF1">
                  <block type="cond_compare" id="b14">
                    <field name="OP">&lt;</field>
                    <value name="LEFT"><block type="val_var" id="b15"><field name="VAR" id="var_bmi">bmi</field></block></value>
                    <value name="RIGHT"><block type="val_number" id="b16"><field name="NUM">25</field></block></value>
                  </block>
                </value>
                <statement name="DO1">
                  <block type="print_text" id="b17"><field name="TEXT">普通体重</field></block>
                </statement>
                <statement name="ELSE">
                  <block type="print_text" id="b18"><field name="TEXT">肥満</field></block>
                </statement>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
