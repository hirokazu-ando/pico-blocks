<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_scores">scores</variable>
    <variable id="var_avg">avg</variable>
    <variable id="var_median">median</variable>
  </variables>
  <block type="py_import_stats" id="b1" x="30" y="30">
    <next>
      <block type="var_set" id="b2">
        <field name="VAR" id="var_scores">scores</field>
        <value name="VALUE">
          <block type="py_list_literal">
            <mutation items="10"/>
            <value name="ITEM0"><block type="val_number"><field name="NUM">78</field></block></value>
            <value name="ITEM1"><block type="val_number"><field name="NUM">92</field></block></value>
            <value name="ITEM2"><block type="val_number"><field name="NUM">65</field></block></value>
            <value name="ITEM3"><block type="val_number"><field name="NUM">88</field></block></value>
            <value name="ITEM4"><block type="val_number"><field name="NUM">70</field></block></value>
            <value name="ITEM5"><block type="val_number"><field name="NUM">55</field></block></value>
            <value name="ITEM6"><block type="val_number"><field name="NUM">98</field></block></value>
            <value name="ITEM7"><block type="val_number"><field name="NUM">72</field></block></value>
            <value name="ITEM8"><block type="val_number"><field name="NUM">80</field></block></value>
            <value name="ITEM9"><block type="val_number"><field name="NUM">61</field></block></value>
          </block>
        </value>
        <next>
          <block type="var_set" id="b3">
            <field name="VAR" id="var_avg">avg</field>
            <value name="VALUE">
              <block type="py_stats_mean" id="b4">
                <value name="DATA">
                  <block type="val_var" id="b5"><field name="VAR" id="var_scores">scores</field></block>
                </value>
              </block>
            </value>
            <next>
              <block type="var_set" id="b6">
                <field name="VAR" id="var_median">median</field>
                <value name="VALUE">
                  <block type="py_stats_median" id="b7">
                    <value name="DATA">
                      <block type="val_var" id="b8"><field name="VAR" id="var_scores">scores</field></block>
                    </value>
                  </block>
                </value>
                <next>
                  <block type="py_custom_stmt" id="b9">
                    <field name="CODE">print("平均:", avg)</field>
                    <next>
                      <block type="py_custom_stmt" id="b10">
                        <field name="CODE">print("中央値:", median)</field>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
