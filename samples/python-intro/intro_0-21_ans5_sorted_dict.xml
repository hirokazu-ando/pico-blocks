  <block type="py_custom_stmt" x="30" y="30">
    <field name="CODE">students = [{"name": "田中", "class": "A", "score": 85}, {"name": "鈴木", "class": "B", "score": 92}, {"name": "山田", "class": "A", "score": 78}, {"name": "伊藤", "class": "B", "score": 88}]</field>
    <next>
      <block type="py_custom_stmt">
        <field name="CODE">result = sorted(students, key=lambda s: (s["class"], -s["score"]))</field>
