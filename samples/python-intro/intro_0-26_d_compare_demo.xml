<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vd">data</variable>
    <variable id="vr">result</variable>
  </variables>
  <block type="var_set" x="30" y="30">
    <field name="VAR" id="vd">data</field>
    <value name="VALUE">
      <block type="py_list_literal">
        <mutation items="6"/>
        <value name="ITEM0"><block type="val_number"><field name="NUM">9</field></block></value>
        <value name="ITEM1"><block type="val_number"><field name="NUM">3</field></block></value>
        <value name="ITEM2"><block type="val_number"><field name="NUM">7</field></block></value>
        <value name="ITEM3"><block type="val_number"><field name="NUM">1</field></block></value>
        <value name="ITEM4"><block type="val_number"><field name="NUM">5</field></block></value>
        <value name="ITEM5"><block type="val_number"><field name="NUM">2</field></block></value>
      </block>
    </value>
    <next>
      <block type="var_set">
        <field name="VAR" id="vr">result</field>
        <value name="VALUE">
          <block type="py_sorted_call">
            <field name="LIST" id="vd">data</field>
            <field name="REVERSE">False</field>
          </block>
        </value>
        <next>
          <block type="py_print">
            <value name="VALUE">
              <block type="py_fstring">
                <field name="PRE">元データ: </field>
                <value name="VAR"><block type="val_var"><field name="VAR" id="vd">data</field></block></value>
                <field name="POST"></field>
              </block>
            </value>
            <next>
              <block type="py_print">
                <value name="VALUE">
                  <block type="py_fstring">
                    <field name="PRE">Python sorted: </field>
                    <value name="VAR"><block type="val_var"><field name="VAR" id="vr">result</field></block></value>
                    <field name="POST"></field>
                  </block>
                </value>
                <next>
                  <block type="py_print">
                    <value name="VALUE">
                      <block type="val_str"><field name="TEXT">バブル・挿入も同じ結果になる（速度だけ違う）</field></block>
                    </value>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
