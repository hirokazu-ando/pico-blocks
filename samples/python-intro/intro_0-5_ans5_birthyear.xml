<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_by">birth_year</variable>
    <variable id="var_age">age</variable>
  </variables>
  <block type="py_input" id="b0" x="30" y="30">
    <field name="TYPE">int</field>
    <field name="VAR" id="var_by">birth_year</field>
    <field name="PROMPT">生まれた年（西暦4桁）を入力してください</field>
    <next>
      <block type="var_set" id="b1">
        <field name="VAR" id="var_age">age</field>
        <value name="VALUE">
          <block type="py_math_op" id="bm">
            <field name="OP">-</field>
            <value name="LEFT"><block type="val_number" id="n1"><field name="NUM">2026</field></block></value>
            <value name="RIGHT"><block type="val_var" id="bvby"><field name="VAR" id="var_by">birth_year</field></block></value>
          </block>
        </value>
        <next>
          <block type="py_print" id="bp">
            <value name="VALUE">
              <block type="py_fstring2_expr" id="bfs">
                <field name="PRE">生まれた年: </field>
                <field name="MID"> → 2026年時点の年齢: </field>
                <field name="POST">歳</field>
                <value name="VAR1"><block type="val_var" id="bv1"><field name="VAR" id="var_by">birth_year</field></block></value>
                <value name="VAR2"><block type="val_var" id="bv2"><field name="VAR" id="var_age">age</field></block></value>
              </block>
            </value>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
