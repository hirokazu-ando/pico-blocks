<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_xs">xs</variable>
    <variable id="var_ys">ys</variable>
    <variable id="var_i">i</variable>
  </variables>
  <block type="py_import_plt" id="b1" x="30" y="30">
    <next>
      <block type="var_set" id="b2">
        <field name="VAR" id="var_xs">xs</field>
        <value name="VALUE"><block type="py_list_empty" id="b3"></block></value>
        <next>
          <block type="var_set" id="b4">
            <field name="VAR" id="var_ys">ys</field>
            <value name="VALUE"><block type="py_list_empty" id="b5"></block></value>
            <next>
              <block type="pico_for_from_to" id="b6">
                <field name="VAR" id="var_i">i</field>
                <value name="START"><block type="val_number"><field name="NUM">1</field></block></value>
                <value name="STOP"><block type="val_number"><field name="NUM">11</field></block></value>
                <value name="STEP"><block type="val_number"><field name="NUM">1</field></block></value>
                <statement name="DO">
                  <block type="py_list_append" id="b7">
                    <field name="LIST" id="var_xs">xs</field>
                    <value name="VALUE"><block type="val_var"><field name="VAR" id="var_i">i</field></block></value>
                    <next>
                      <block type="py_list_append" id="b8">
                        <field name="LIST" id="var_ys">ys</field>
                        <value name="VALUE">
                          <block type="py_math_op" id="b9">
                            <field name="OP">**</field>
                            <value name="LEFT"><block type="val_var"><field name="VAR" id="var_i">i</field></block></value>
                            <value name="RIGHT"><block type="val_number"><field name="NUM">2</field></block></value>
                          </block>
                        </value>
                      </block>
                    </next>
                  </block>
                </statement>
                <next>
                  <block type="py_plt_plot" id="b10">
                    <value name="X"><block type="val_var"><field name="VAR" id="var_xs">xs</field></block></value>
                    <value name="Y"><block type="val_var"><field name="VAR" id="var_ys">ys</field></block></value>
                    <next>
                      <block type="py_plt_title" id="b11">
                        <value name="TEXT"><block type="val_str"><field name="TEXT">y = x²（1〜10）</field></block></value>
                        <next>
                          <block type="py_plt_xlabel" id="b12">
                            <value name="TEXT"><block type="val_str"><field name="TEXT">x</field></block></value>
                            <next>
                              <block type="py_plt_ylabel" id="b13">
                                <value name="TEXT"><block type="val_str"><field name="TEXT">y</field></block></value>
                                <next>
                                  <block type="py_plt_show" id="b14"></block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
