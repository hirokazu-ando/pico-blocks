<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vc">counter</variable>
    <variable id="vw">words</variable>
    <variable id="vwd">word</variable>
    <variable id="vcnt">content</variable>
    <variable id="vcnt2">count</variable>
  </variables>
  <block type="py_file_write" x="30" y="30">
    <field name="FILENAME">text.txt</field>
    <value name="CONTENT">
      <block type="val_str"><field name="TEXT">the cat sat on the mat the cat\n</field></block>
    </value>
    <next>
      <block type="var_set">
        <field name="VAR" id="vc">counter</field>
        <value name="VALUE">
          <block type="py_dict_new"></block>
        </value>
        <next>
          <block type="py_file_read">
            <field name="FILENAME">text.txt</field>
            <field name="VAR" id="vcnt">content</field>
            <next>
              <block type="var_set">
                <field name="VAR" id="vw">words</field>
                <value name="VALUE">
                  <block type="py_str_split">
                    <field name="VAR" id="vcnt">content</field>
                    <field name="SEP"></field>
                  </block>
                </value>
                <next>
                  <block type="py_for_list">
                    <field name="VAR" id="vwd">word</field>
                    <field name="LIST" id="vw">words</field>
                    <statement name="DO">
                      <block type="py_dict_set">
                        <field name="DICT" id="vc">counter</field>
                        <value name="KEY">
                          <block type="val_var"><field name="VAR" id="vwd">word</field></block>
                        </value>
                        <value name="VAL">
                          <block type="py_math_op">
                            <field name="OP">+</field>
                            <value name="LEFT">
                              <block type="py_dict_get_default">
                                <field name="DICT" id="vc">counter</field>
                                <value name="KEY">
                                  <block type="val_var"><field name="VAR" id="vwd">word</field></block>
                                </value>
                                <value name="DEFAULT">
                                  <block type="val_number"><field name="NUM">0</field></block>
                                </value>
                              </block>
                            </value>
                            <value name="RIGHT">
                              <block type="val_number"><field name="NUM">1</field></block>
                            </value>
                          </block>
                        </value>
                      </block>
                    </statement>
                    <next>
                      <block type="py_for_dict_items_sorted">
                        <field name="DICT" id="vc">counter</field>
                        <field name="KEY_VAR" id="vwd">word</field>
                        <field name="VAL_VAR" id="vcnt2">count</field>
                        <statement name="DO">
                          <block type="py_print">
                            <value name="VALUE">
                              <block type="py_fstring2">
                                <field name="PRE"></field>
                                <field name="VAR1" id="vwd">word</field>
                                <field name="MID">: </field>
                                <field name="VAR2" id="vcnt2">count</field>
                                <field name="POST">回</field>
                              </block>
                            </value>
                          </block>
                        </statement>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
