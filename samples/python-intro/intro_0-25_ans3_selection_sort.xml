<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vd">data</variable>
    <variable id="vn">n</variable>
  </variables>
  <block type="var_set" x="30" y="30">
    <field name="VAR" id="vd">data</field>
    <value name="VALUE">
      <block type="py_list_literal">
        <mutation items="6"/>
        <value name="ITEM0"><block type="val_number"><field name="NUM">9</field></block></value>
        <value name="ITEM1"><block type="val_number"><field name="NUM">3</field></block></value>
        <value name="ITEM2"><block type="val_number"><field name="NUM">5</field></block></value>
        <value name="ITEM3"><block type="val_number"><field name="NUM">1</field></block></value>
        <value name="ITEM4"><block type="val_number"><field name="NUM">7</field></block></value>
        <value name="ITEM5"><block type="val_number"><field name="NUM">2</field></block></value>
      </block>
    </value>
    <next>
      <block type="var_set">
        <field name="VAR" id="vn">n</field>
        <value name="VALUE">
          <block type="py_list_len">
            <field name="LIST" id="vd">data</field>
          </block>
        </value>
        <next>
          <block type="py_custom_stmt">
            <field name="CODE">for i in range(n - 1):</field>
            <next>
              <block type="py_custom_stmt">
                <field name="CODE">    min_idx = i</field>
                <next>
                  <block type="py_custom_stmt">
                    <field name="CODE">    for j in range(i + 1, n):</field>
                    <next>
                      <block type="py_custom_stmt">
                        <field name="CODE">        if data[j] &lt; data[min_idx]:</field>
                        <next>
                          <block type="py_custom_stmt">
                            <field name="CODE">            min_idx = j</field>
                            <next>
                              <block type="py_custom_stmt">
                                <field name="CODE">    data[i], data[min_idx] = data[min_idx], data[i]</field>
                                <next>
                                  <block type="py_custom_stmt">
                                    <field name="CODE">    print(f"ステップ{i+1}: {data}")</field>
                                    <next>
                                      <block type="py_custom_stmt">
                                        <field name="CODE">print("完成:", data)</field>
                                      </block>
                                    </next>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
