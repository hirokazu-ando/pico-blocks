<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_month">month</variable>
    <variable id="var_sales">sales</variable>
  </variables>
  <block type="py_import_plt" id="b0" x="30" y="30">
    <next>
      <block type="var_set" id="b1">
        <field name="VAR" id="var_month">month</field>
        <value name="VALUE">
          <block type="py_list_literal">
            <mutation items="6"/>
            <value name="ITEM0"><block type="val_number"><field name="NUM">1</field></block></value>
            <value name="ITEM1"><block type="val_number"><field name="NUM">2</field></block></value>
            <value name="ITEM2"><block type="val_number"><field name="NUM">3</field></block></value>
            <value name="ITEM3"><block type="val_number"><field name="NUM">4</field></block></value>
            <value name="ITEM4"><block type="val_number"><field name="NUM">5</field></block></value>
            <value name="ITEM5"><block type="val_number"><field name="NUM">6</field></block></value>
          </block>
        </value>
        <next>
          <block type="var_set" id="b2">
            <field name="VAR" id="var_sales">sales</field>
            <value name="VALUE">
              <block type="py_list_literal">
                <mutation items="6"/>
                <value name="ITEM0"><block type="val_number"><field name="NUM">120</field></block></value>
                <value name="ITEM1"><block type="val_number"><field name="NUM">150</field></block></value>
                <value name="ITEM2"><block type="val_number"><field name="NUM">180</field></block></value>
                <value name="ITEM3"><block type="val_number"><field name="NUM">210</field></block></value>
                <value name="ITEM4"><block type="val_number"><field name="NUM">200</field></block></value>
                <value name="ITEM5"><block type="val_number"><field name="NUM">240</field></block></value>
              </block>
            </value>
            <next>
              <block type="py_plt_plot" id="b3">
                <value name="X"><block type="val_var"><field name="VAR" id="var_month">month</field></block></value>
                <value name="Y"><block type="val_var"><field name="VAR" id="var_sales">sales</field></block></value>
                <next>
                  <block type="py_plt_title" id="b4">
                    <value name="TEXT"><block type="val_str"><field name="TEXT">月別売上の推移</field></block></value>
                    <next>
                      <block type="py_plt_xlabel" id="b5">
                        <value name="TEXT"><block type="val_str"><field name="TEXT">月</field></block></value>
                        <next>
                          <block type="py_plt_ylabel" id="b6">
                            <value name="TEXT"><block type="val_str"><field name="TEXT">売上（万円）</field></block></value>
                            <next>
                              <block type="py_plt_show" id="b7"></block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
