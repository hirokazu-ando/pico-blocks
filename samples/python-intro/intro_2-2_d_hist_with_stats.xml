<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_scores">scores</variable>
    <variable id="var_avg">avg</variable>
  </variables>
  <block type="py_import_stats" id="b1" x="30" y="30">
    <next>
      <block type="py_import_plt" id="b2">
        <next>
          <block type="var_set" id="b3">
            <field name="VAR" id="var_scores">scores</field>
            <value name="VALUE">
              <block type="py_list_literal">
                <mutation items="10"/>
                <value name="ITEM0"><block type="val_number"><field name="NUM">78</field></block></value>
                <value name="ITEM1"><block type="val_number"><field name="NUM">92</field></block></value>
                <value name="ITEM2"><block type="val_number"><field name="NUM">65</field></block></value>
                <value name="ITEM3"><block type="val_number"><field name="NUM">88</field></block></value>
                <value name="ITEM4"><block type="val_number"><field name="NUM">70</field></block></value>
                <value name="ITEM5"><block type="val_number"><field name="NUM">55</field></block></value>
                <value name="ITEM6"><block type="val_number"><field name="NUM">98</field></block></value>
                <value name="ITEM7"><block type="val_number"><field name="NUM">72</field></block></value>
                <value name="ITEM8"><block type="val_number"><field name="NUM">80</field></block></value>
                <value name="ITEM9"><block type="val_number"><field name="NUM">61</field></block></value>
              </block>
            </value>
            <next>
              <block type="var_set" id="b4">
                <field name="VAR" id="var_avg">avg</field>
                <value name="VALUE">
                  <block type="py_stats_mean">
                    <value name="DATA"><block type="val_var"><field name="VAR" id="var_scores">scores</field></block></value>
                  </block>
                </value>
                <next>
                  <block type="py_print_multi" id="p1">
                    <mutation items="4"/>
                    <value name="ITEM0"><block type="val_str"><field name="TEXT">平均:</field></block></value>
                    <value name="ITEM1"><block type="val_var"><field name="VAR" id="var_avg">avg</field></block></value>
                    <value name="ITEM2"><block type="val_str"><field name="TEXT">　中央値:</field></block></value>
                    <value name="ITEM3">
                      <block type="py_stats_median">
                        <value name="DATA"><block type="val_var"><field name="VAR" id="var_scores">scores</field></block></value>
                      </block>
                    </value>
                    <next>
                      <block type="py_print_multi" id="p2">
                        <mutation items="2"/>
                        <value name="ITEM0"><block type="val_str"><field name="TEXT">標準偏差:</field></block></value>
                        <value name="ITEM1">
                          <block type="py_stats_stdev">
                            <value name="DATA"><block type="val_var"><field name="VAR" id="var_scores">scores</field></block></value>
                          </block>
                        </value>
                        <next>
                          <block type="py_plt_hist" id="b5">
                            <value name="DATA"><block type="val_var"><field name="VAR" id="var_scores">scores</field></block></value>
                            <field name="BINS">5</field>
                            <next>
                              <block type="py_plt_title" id="b6">
                                <value name="TEXT">
                                  <block type="py_fstring">
                                    <field name="PRE">得点分布（平均=</field>
                                    <value name="VAR"><block type="val_var"><field name="VAR" id="var_avg">avg</field></block></value>
                                    <field name="POST">）</field>
                                  </block>
                                </value>
                                <next>
                                  <block type="py_plt_xlabel" id="b7">
                                    <value name="TEXT"><block type="val_str"><field name="TEXT">点数</field></block></value>
                                    <next>
                                      <block type="py_plt_ylabel" id="b8">
                                        <value name="TEXT"><block type="val_str"><field name="TEXT">人数</field></block></value>
                                        <next>
                                          <block type="py_plt_show" id="b9"></block>
                                        </next>
                                      </block>
                                    </next>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
