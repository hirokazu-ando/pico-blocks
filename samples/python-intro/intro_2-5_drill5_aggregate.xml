<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_scores">scores</variable>
    <variable id="var_ranked">ranked</variable>
    <variable id="var_high">high</variable>
    <variable id="var_s">s</variable>
  </variables>
  <block type="var_set" id="b1" x="30" y="30">
    <field name="VAR" id="var_scores">scores</field>
    <value name="VALUE">
      <block type="py_list_literal">
        <mutation items="8"/>
        <value name="ITEM0"><block type="val_number"><field name="NUM">72</field></block></value>
        <value name="ITEM1"><block type="val_number"><field name="NUM">85</field></block></value>
        <value name="ITEM2"><block type="val_number"><field name="NUM">91</field></block></value>
        <value name="ITEM3"><block type="val_number"><field name="NUM">68</field></block></value>
        <value name="ITEM4"><block type="val_number"><field name="NUM">95</field></block></value>
        <value name="ITEM5"><block type="val_number"><field name="NUM">60</field></block></value>
        <value name="ITEM6"><block type="val_number"><field name="NUM">82</field></block></value>
        <value name="ITEM7"><block type="val_number"><field name="NUM">88</field></block></value>
      </block>
    </value>
    <next>
      <block type="var_set" id="b2">
        <field name="VAR" id="var_ranked">ranked</field>
        <value name="VALUE">
          <block type="py_sorted_call">
            <field name="LIST" id="var_scores">scores</field>
            <field name="REVERSE">True</field>
          </block>
        </value>
        <next>
          <block type="var_set" id="b3">
            <field name="VAR" id="var_high">high</field>
            <value name="VALUE">
              <block type="py_list_comp_if">
                <field name="VAR" id="var_s">s</field>
                <value name="EXPR"><block type="val_var"><field name="VAR" id="var_s">s</field></block></value>
                <value name="LIST"><block type="val_var"><field name="VAR" id="var_scores">scores</field></block></value>
                <value name="COND">
                  <block type="cond_compare">
                    <field name="OP">&gt;=</field>
                    <value name="LEFT"><block type="val_var"><field name="VAR" id="var_s">s</field></block></value>
                    <value name="RIGHT"><block type="val_number"><field name="NUM">80</field></block></value>
                  </block>
                </value>
              </block>
            </value>
            <next>
              <block type="py_print_multi" id="p1">
                <mutation items="2"/>
                <value name="ITEM0"><block type="val_str"><field name="TEXT">高い順:</field></block></value>
                <value name="ITEM1"><block type="val_var"><field name="VAR" id="var_ranked">ranked</field></block></value>
                <next>
                  <block type="py_print_multi" id="p2">
                    <mutation items="2"/>
                    <value name="ITEM0"><block type="val_str"><field name="TEXT">80点以上:</field></block></value>
                    <value name="ITEM1"><block type="val_var"><field name="VAR" id="var_high">high</field></block></value>
                    <next>
                      <block type="py_print_multi" id="p3">
                        <mutation items="2"/>
                        <value name="ITEM0"><block type="val_str"><field name="TEXT">人数:</field></block></value>
                        <value name="ITEM1">
                          <block type="py_list_len">
                            <field name="LIST" id="var_high">high</field>
                          </block>
                        </value>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
