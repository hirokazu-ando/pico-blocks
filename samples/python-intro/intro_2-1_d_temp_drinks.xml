<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_temp">temp</variable>
    <variable id="var_bottles">bottles</variable>
  </variables>
  <block type="py_import_plt" id="b1" x="30" y="30">
    <next>
      <block type="var_set" id="b2">
        <field name="VAR" id="var_temp">temp</field>
        <value name="VALUE">
          <block type="py_list_literal">
            <mutation items="6"/>
            <value name="ITEM0"><block type="val_number"><field name="NUM">10</field></block></value>
            <value name="ITEM1"><block type="val_number"><field name="NUM">15</field></block></value>
            <value name="ITEM2"><block type="val_number"><field name="NUM">20</field></block></value>
            <value name="ITEM3"><block type="val_number"><field name="NUM">25</field></block></value>
            <value name="ITEM4"><block type="val_number"><field name="NUM">30</field></block></value>
            <value name="ITEM5"><block type="val_number"><field name="NUM">35</field></block></value>
          </block>
        </value>
        <next>
          <block type="var_set" id="b3">
            <field name="VAR" id="var_bottles">bottles</field>
            <value name="VALUE">
              <block type="py_list_literal">
                <mutation items="6"/>
                <value name="ITEM0"><block type="val_number"><field name="NUM">20</field></block></value>
                <value name="ITEM1"><block type="val_number"><field name="NUM">30</field></block></value>
                <value name="ITEM2"><block type="val_number"><field name="NUM">50</field></block></value>
                <value name="ITEM3"><block type="val_number"><field name="NUM">70</field></block></value>
                <value name="ITEM4"><block type="val_number"><field name="NUM">100</field></block></value>
                <value name="ITEM5"><block type="val_number"><field name="NUM">130</field></block></value>
              </block>
            </value>
            <next>
              <block type="py_plt_scatter" id="b4">
                <value name="X"><block type="val_var" id="b5"><field name="VAR" id="var_temp">temp</field></block></value>
                <value name="Y"><block type="val_var" id="b6"><field name="VAR" id="var_bottles">bottles</field></block></value>
                <next>
                  <block type="py_plt_title" id="b7">
                    <value name="TEXT"><block type="val_str" id="b8"><field name="TEXT">気温と飲料消費量</field></block></value>
                    <next>
                      <block type="py_plt_xlabel" id="b9">
                        <value name="TEXT"><block type="val_str" id="b10"><field name="TEXT">気温（℃）</field></block></value>
                        <next>
                          <block type="py_plt_ylabel" id="b11">
                            <value name="TEXT"><block type="val_str" id="b12"><field name="TEXT">消費量（本）</field></block></value>
                            <next>
                              <block type="py_plt_show" id="b13"></block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
