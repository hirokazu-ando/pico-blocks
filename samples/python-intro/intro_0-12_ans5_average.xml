<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables><variable id="var_scores">scores</variable><variable id="var_score">score</variable><variable id="var_total">total</variable><variable id="var_average">average</variable></variables>
  <block type="var_set" id="b1" x="30" y="30">
    <field name="VAR" id="var_scores">scores</field>
    <value name="VALUE"><block type="py_list_empty" id="b_5e"></block></value>
    <next><block type="py_list_append" id="b_a10">
      <field name="LIST" id="var_scores">scores</field>
      <value name="VALUE"><block type="val_number" id="bv10"><field name="NUM">80</field></block></value>
      <next><block type="py_list_append" id="b_a11">
      <field name="LIST" id="var_scores">scores</field>
      <value name="VALUE"><block type="val_number" id="bv11"><field name="NUM">65</field></block></value>
      <next><block type="py_list_append" id="b_a12">
      <field name="LIST" id="var_scores">scores</field>
      <value name="VALUE"><block type="val_number" id="bv12"><field name="NUM">90</field></block></value>
      <next><block type="py_list_append" id="b_a13">
      <field name="LIST" id="var_scores">scores</field>
      <value name="VALUE"><block type="val_number" id="bv13"><field name="NUM">75</field></block></value>
      <next><block type="var_set" id="b_t0">
        <field name="VAR" id="var_total">total</field>
        <value name="VALUE"><block type="val_number" id="bv_t0"><field name="NUM">0</field></block></value>
        <next>
          <block type="py_for_list" id="b_for">
            <field name="VAR" id="var_score">score</field>
            <field name="LIST" id="var_scores">scores</field>
            <statement name="DO">
              <block type="var_change" id="b_ch">
                <field name="VAR" id="var_total">total</field>
                <value name="AMOUNT"><block type="val_var" id="bv_sc"><field name="VAR" id="var_score">score</field></block></value>
              </block>
            </statement>
            <next>
              <block type="var_set" id="b_avg">
                <field name="VAR" id="var_average">average</field>
                <value name="VALUE">
                  <block type="py_math_op" id="b_div">
                    <field name="OP">/</field>
                    <value name="LEFT"><block type="val_var" id="bv_tot"><field name="VAR" id="var_total">total</field></block></value>
                    <value name="RIGHT"><block type="py_list_len" id="b_len"><field name="LIST" id="var_scores">scores</field></block></value>
                  </block>
                </value>
                <next>
                  <block type="print_var_label" id="b_pl1">
                    <field name="LABEL">合計:</field>
                    <field name="VAR" id="var_total">total</field>
                    <next>
                      <block type="print_var_label" id="b_pl2">
                        <field name="LABEL">平均:</field>
                        <field name="VAR" id="var_average">average</field>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block></next>
    </block></next>
    </block></next>
    </block></next>
    </block></next>
  </block>
</xml>
