<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_scores">scores</variable>
    <variable id="var_score">score</variable>
    <variable id="var_total">total</variable>
    <variable id="var_average">average</variable>
  </variables>
  <block type="var_set" id="b1" x="30" y="30">
    <field name="VAR" id="var_scores">scores</field>
    <value name="VALUE"><block type="py_custom_expr" id="b2"><field name="CODE">[80, 65, 90, 75]</field></block></value>
    <next>
      <block type="var_set" id="b3">
        <field name="VAR" id="var_total">total</field>
        <value name="VALUE"><block type="val_number" id="b4"><field name="NUM">0</field></block></value>
        <next>
          <block type="py_for_list" id="b5">
            <field name="VAR" id="var_score">score</field>
            <field name="LIST" id="var_scores">scores</field>
            <statement name="DO">
              <block type="var_change" id="b6">
                <field name="VAR" id="var_total">total</field>
                <value name="AMOUNT"><block type="val_var" id="b7"><field name="VAR" id="var_score">score</field></block></value>
              </block>
            </statement>
            <next>
              <block type="var_set" id="b8">
                <field name="VAR" id="var_average">average</field>
                <value name="VALUE">
                  <block type="py_math_op" id="b9">
                    <field name="OP">/</field>
                    <value name="LEFT"><block type="val_var" id="b10"><field name="VAR" id="var_total">total</field></block></value>
                    <value name="RIGHT"><block type="py_list_len" id="b11"><field name="LIST" id="var_scores">scores</field></block></value>
                  </block>
                </value>
                <next>
                  <block type="print_var_label" id="b12">
                    <field name="LABEL">合計:</field>
                    <field name="VAR" id="var_total">total</field>
                    <next>
                      <block type="print_var_label" id="b13">
                        <field name="LABEL">平均:</field>
                        <field name="VAR" id="var_average">average</field>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
