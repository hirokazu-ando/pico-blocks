<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_a">a</variable>
    <variable id="var_b">b</variable>
  </variables>
  <block type="py_input" id="b0" x="30" y="30">
    <field name="TYPE">int</field>
    <field name="VAR" id="var_a">a</field>
    <field name="PROMPT">整数aを入力してください</field>
    <next>
      <block type="py_input" id="b1">
        <field name="TYPE">int</field>
        <field name="VAR" id="var_b">b</field>
        <field name="PROMPT">整数bを入力してください</field>
        <next>
          <block type="py_print" id="bp1">
            <value name="VALUE">
              <block type="py_fstring" id="bf1">
                <field name="PRE">a + b = </field>
                <field name="POST"></field>
                <value name="VAR">
                  <block type="py_math_op" id="bm1">
                    <field name="OP">+</field>
                    <value name="LEFT"><block type="val_var" id="va1"><field name="VAR" id="var_a">a</field></block></value>
                    <value name="RIGHT"><block type="val_var" id="vb1"><field name="VAR" id="var_b">b</field></block></value>
                  </block>
                </value>
              </block>
            </value>
            <next>
              <block type="py_print" id="bp2">
                <value name="VALUE">
                  <block type="py_fstring" id="bf2">
                    <field name="PRE">a - b = </field>
                    <field name="POST"></field>
                    <value name="VAR">
                      <block type="py_math_op" id="bm2">
                        <field name="OP">-</field>
                        <value name="LEFT"><block type="val_var" id="va2"><field name="VAR" id="var_a">a</field></block></value>
                        <value name="RIGHT"><block type="val_var" id="vb2"><field name="VAR" id="var_b">b</field></block></value>
                      </block>
                    </value>
                  </block>
                </value>
                <next>
                  <block type="py_print" id="bp3">
                    <value name="VALUE">
                      <block type="py_fstring" id="bf3">
                        <field name="PRE">a * b = </field>
                        <field name="POST"></field>
                        <value name="VAR">
                          <block type="py_math_op" id="bm3">
                            <field name="OP">*</field>
                            <value name="LEFT"><block type="val_var" id="va3"><field name="VAR" id="var_a">a</field></block></value>
                            <value name="RIGHT"><block type="val_var" id="vb3"><field name="VAR" id="var_b">b</field></block></value>
                          </block>
                        </value>
                      </block>
                    </value>
                    <next>
                      <block type="py_print" id="bp4">
                        <value name="VALUE">
                          <block type="py_fstring" id="bf4">
                            <field name="PRE">a / b = </field>
                            <field name="POST"></field>
                            <value name="VAR">
                              <block type="py_math_op" id="bm4">
                                <field name="OP">/</field>
                                <value name="LEFT"><block type="val_var" id="va4"><field name="VAR" id="var_a">a</field></block></value>
                                <value name="RIGHT"><block type="val_var" id="vb4"><field name="VAR" id="var_b">b</field></block></value>
                              </block>
                            </value>
                          </block>
                        </value>
                        <next>
                          <block type="py_print" id="bp5">
                            <value name="VALUE">
                              <block type="py_fstring" id="bf5">
                                <field name="PRE">a // b = </field>
                                <field name="POST"></field>
                                <value name="VAR">
                                  <block type="py_math_op" id="bm5">
                                    <field name="OP">//</field>
                                    <value name="LEFT"><block type="val_var" id="va5"><field name="VAR" id="var_a">a</field></block></value>
                                    <value name="RIGHT"><block type="val_var" id="vb5"><field name="VAR" id="var_b">b</field></block></value>
                                  </block>
                                </value>
                              </block>
                            </value>
                            <next>
                              <block type="py_print" id="bp6">
                                <value name="VALUE">
                                  <block type="py_fstring" id="bf6">
                                    <field name="PRE">a % b = </field>
                                    <field name="POST"></field>
                                    <value name="VAR">
                                      <block type="py_math_op" id="bm6">
                                        <field name="OP">%</field>
                                        <value name="LEFT"><block type="val_var" id="va6"><field name="VAR" id="var_a">a</field></block></value>
                                        <value name="RIGHT"><block type="val_var" id="vb6"><field name="VAR" id="var_b">b</field></block></value>
                                      </block>
                                    </value>
                                  </block>
                                </value>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
