<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_x">x</variable>
    <variable id="var_y">y</variable>
  </variables>
  <block type="py_import_plt" id="b1" x="30" y="30">
    <next>
      <block type="var_set" id="b2">
        <field name="VAR" id="var_x">x</field>
        <value name="VALUE">
          <block type="py_custom_expr" id="b3"><field name="CODE">[1, 2, 3, 4, 5]</field></block>
        </value>
        <next>
          <block type="var_set" id="b4">
            <field name="VAR" id="var_y">y</field>
            <value name="VALUE">
              <block type="py_custom_expr" id="b5"><field name="CODE">[1, 4, 9, 16, 25]</field></block>
            </value>
            <next>
              <block type="py_plt_plot" id="b6">
                <value name="X"><block type="val_var" id="b7"><field name="VAR" id="var_x">x</field></block></value>
                <value name="Y"><block type="val_var" id="b8"><field name="VAR" id="var_y">y</field></block></value>
                <next>
                  <block type="py_plt_title" id="b9">
                    <value name="TEXT"><block type="val_str" id="b10"><field name="TEXT">二乗グラフ</field></block></value>
                    <next>
                      <block type="py_plt_show" id="b11"></block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
