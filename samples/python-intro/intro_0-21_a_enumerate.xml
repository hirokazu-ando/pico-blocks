<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_fruits">fruits</variable>
    <variable id="var_i">i</variable>
    <variable id="var_f">f</variable>
  </variables>
  <block type="py_enumerate_for" x="30" y="30">
    <field name="IDX" id="var_i">i</field>
    <field name="VAL" id="var_f">f</field>
    <field name="LIST" id="var_fruits">fruits</field>
    <statement name="DO">
      <block type="py_print">
        <value name="VALUE">
          <block type="py_str_concat">
            <value name="A">
              <block type="py_str_concat">
                <value name="A"><block type="val_var"><field name="VAR" id="var_i">i</field></block></value>
                <value name="B"><block type="val_str"><field name="TEXT">: </field></block></value>
              </block>
            </value>
            <value name="B"><block type="val_var"><field name="VAR" id="var_f">f</field></block></value>
          </block>
        </value>
      </block>
    </statement>
  </block>
</xml>
