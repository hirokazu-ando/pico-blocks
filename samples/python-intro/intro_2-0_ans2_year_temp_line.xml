<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_months">months</variable>
    <variable id="var_temps">temps</variable>
  </variables>
  <block type="py_import_plt" id="b1" x="30" y="30">
    <next>
      <block type="var_set" id="b2">
        <field name="VAR" id="var_months">months</field>
        <value name="VALUE">
          <block type="py_list_literal" id="b3">
            <mutation items="12" vertical="true"/>
            <value name="ITEM0"><block type="val_str"><field name="TEXT">1月</field></block></value>
            <value name="ITEM1"><block type="val_str"><field name="TEXT">2月</field></block></value>
            <value name="ITEM2"><block type="val_str"><field name="TEXT">3月</field></block></value>
            <value name="ITEM3"><block type="val_str"><field name="TEXT">4月</field></block></value>
            <value name="ITEM4"><block type="val_str"><field name="TEXT">5月</field></block></value>
            <value name="ITEM5"><block type="val_str"><field name="TEXT">6月</field></block></value>
            <value name="ITEM6"><block type="val_str"><field name="TEXT">7月</field></block></value>
            <value name="ITEM7"><block type="val_str"><field name="TEXT">8月</field></block></value>
            <value name="ITEM8"><block type="val_str"><field name="TEXT">9月</field></block></value>
            <value name="ITEM9"><block type="val_str"><field name="TEXT">10月</field></block></value>
            <value name="ITEM10"><block type="val_str"><field name="TEXT">11月</field></block></value>
            <value name="ITEM11"><block type="val_str"><field name="TEXT">12月</field></block></value>
          </block>
        </value>
        <next>
          <block type="var_set" id="b4">
            <field name="VAR" id="var_temps">temps</field>
            <value name="VALUE">
              <block type="py_list_literal" id="b5">
                <mutation items="12" vertical="true"/>
                <value name="ITEM0"><block type="val_number"><field name="NUM">6</field></block></value>
                <value name="ITEM1"><block type="val_number"><field name="NUM">7</field></block></value>
                <value name="ITEM2"><block type="val_number"><field name="NUM">10</field></block></value>
                <value name="ITEM3"><block type="val_number"><field name="NUM">15</field></block></value>
                <value name="ITEM4"><block type="val_number"><field name="NUM">20</field></block></value>
                <value name="ITEM5"><block type="val_number"><field name="NUM">23</field></block></value>
                <value name="ITEM6"><block type="val_number"><field name="NUM">27</field></block></value>
                <value name="ITEM7"><block type="val_number"><field name="NUM">29</field></block></value>
                <value name="ITEM8"><block type="val_number"><field name="NUM">25</field></block></value>
                <value name="ITEM9"><block type="val_number"><field name="NUM">19</field></block></value>
                <value name="ITEM10"><block type="val_number"><field name="NUM">13</field></block></value>
                <value name="ITEM11"><block type="val_number"><field name="NUM">8</field></block></value>
              </block>
            </value>
            <next>
              <block type="py_plt_plot" id="b6">
                <value name="X"><block type="val_var"><field name="VAR" id="var_months">months</field></block></value>
                <value name="Y"><block type="val_var"><field name="VAR" id="var_temps">temps</field></block></value>
                <next>
                  <block type="py_plt_title" id="b7">
                    <value name="TEXT"><block type="val_str"><field name="TEXT">大阪の月別平均気温</field></block></value>
                    <next>
                      <block type="py_plt_xlabel" id="b8">
                        <value name="TEXT"><block type="val_str"><field name="TEXT">月</field></block></value>
                        <next>
                          <block type="py_plt_ylabel" id="b9">
                            <value name="TEXT"><block type="val_str"><field name="TEXT">気温(℃)</field></block></value>
                            <next>
                              <block type="py_plt_show" id="b10"></block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
