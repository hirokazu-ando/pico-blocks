<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_word">word</variable>
    <variable id="var_text">text</variable>
  </variables>
  <block type="var_set" id="b0" x="30" y="30">
    <field name="VAR" id="var_word">word</field>
    <value name="VALUE"><block type="val_str" id="vs1"><field name="TEXT">Python</field></block></value>
    <next>
      <block type="py_custom_stmt" id="cs1">
        <field name="CODE">print(word[::-1])</field>
        <next>
          <block type="var_set" id="b1">
            <field name="VAR" id="var_text">text</field>
            <value name="VALUE"><block type="val_str" id="vs2"><field name="TEXT">level</field></block></value>
            <next>
              <block type="py_custom_stmt" id="cs2">
                <field name="CODE">print(text == text[::-1])</field>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
