<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vn">names</variable>
    <variable id="vsc">scores</variable>
    <variable id="vna">name</variable>
    <variable id="vsk">score</variable>
  </variables>
  <block type="var_set" x="30" y="30">
    <field name="VAR" id="vn">names</field>
    <value name="VALUE">
      <block type="py_list_literal">
        <mutation items="3"/>
        <value name="ITEM0"><block type="val_str"><field name="TEXT">Alice</field></block></value>
        <value name="ITEM1"><block type="val_str"><field name="TEXT">Bob</field></block></value>
        <value name="ITEM2"><block type="val_str"><field name="TEXT">Carol</field></block></value>
      </block>
    </value>
    <next>
      <block type="var_set">
        <field name="VAR" id="vsc">scores</field>
        <value name="VALUE">
          <block type="py_list_literal">
            <mutation items="3"/>
            <value name="ITEM0"><block type="val_number"><field name="NUM">88</field></block></value>
            <value name="ITEM1"><block type="val_number"><field name="NUM">75</field></block></value>
            <value name="ITEM2"><block type="val_number"><field name="NUM">92</field></block></value>
          </block>
        </value>
        <next>
          <block type="py_zip_for">
            <field name="VAR_A" id="vna">name</field>
            <field name="VAR_B" id="vsk">score</field>
            <field name="LIST_A" id="vn">names</field>
            <field name="LIST_B" id="vsc">scores</field>
            <statement name="DO">
              <block type="py_print">
                <value name="VALUE">
                  <block type="py_fstring2">
                    <field name="PRE"></field>
                    <field name="VAR1" id="vna">name</field>
                    <field name="MID">: </field>
                    <field name="VAR2" id="vsk">score</field>
                    <field name="POST">点</field>
                  </block>
                </value>
              </block>
            </statement>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
