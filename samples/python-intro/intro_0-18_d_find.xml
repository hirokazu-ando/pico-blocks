<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vtext">text</variable>
    <variable id="vpos">pos</variable>
    <variable id="vpos2">pos2</variable>
    <variable id="vpos3">pos3</variable>
  </variables>
  <block type="var_set" x="30" y="30">
    <field name="VAR" id="vtext">text</field>
    <value name="VALUE"><block type="val_str"><field name="TEXT">Python is fun and Python is powerful</field></block></value>
    <next>
      <block type="var_set">
        <field name="VAR" id="vpos">pos</field>
        <value name="VALUE">
          <block type="py_str_find">
            <field name="VAR" id="vtext">text</field>
            <field name="SUB">Python</field>
          </block>
        </value>
        <next>
          <block type="py_print">
            <value name="VALUE"><block type="val_var"><field name="VAR" id="vpos">pos</field></block></value>
            <next>
              <block type="var_set">
                <field name="VAR" id="vpos2">pos2</field>
                <value name="VALUE">
                  <block type="py_str_find_from">
                    <field name="VAR" id="vtext">text</field>
                    <field name="SUB">Python</field>
                    <field name="START">1</field>
                  </block>
                </value>
                <next>
                  <block type="py_print">
                    <value name="VALUE"><block type="val_var"><field name="VAR" id="vpos2">pos2</field></block></value>
                    <next>
                      <block type="var_set">
                        <field name="VAR" id="vpos3">pos3</field>
                        <value name="VALUE">
                          <block type="py_str_find">
                            <field name="VAR" id="vtext">text</field>
                            <field name="SUB">Java</field>
                          </block>
                        </value>
                        <next>
                          <block type="py_print">
                            <value name="VALUE"><block type="val_var"><field name="VAR" id="vpos3">pos3</field></block></value>
                            <next>
                              <block type="controls_if">
                                <value name="IF0">
                                  <block type="cond_compare">
                                    <field name="OP">!=</field>
                                    <value name="LEFT">
                                      <block type="py_str_find">
                                        <field name="VAR" id="vtext">text</field>
                                        <field name="SUB">fun</field>
                                      </block>
                                    </value>
                                    <value name="RIGHT"><block type="val_number"><field name="NUM">-1</field></block></value>
                                  </block>
                                </value>
                                <statement name="DO0">
                                  <block type="py_print">
                                    <value name="VALUE"><block type="val_str"><field name="TEXT">fun が含まれている</field></block></value>
                                  </block>
                                </statement>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
