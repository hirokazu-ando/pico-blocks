<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vc">colors</variable>
    <variable id="vr">result</variable>
    <variable id="vn">nums</variable>
    <variable id="vcl">csv_line</variable>
  </variables>
  <block type="var_set" x="30" y="30">
    <field name="VAR" id="vc">colors</field>
    <value name="VALUE">
      <block type="py_list_literal">
        <mutation items="3"/>
        <value name="ITEM0"><block type="val_str"><field name="TEXT">赤</field></block></value>
        <value name="ITEM1"><block type="val_str"><field name="TEXT">青</field></block></value>
        <value name="ITEM2"><block type="val_str"><field name="TEXT">緑</field></block></value>
      </block>
    </value>
    <next>
      <block type="var_set">
        <field name="VAR" id="vr">result</field>
        <value name="VALUE"><block type="py_str_join"><field name="SEP"> - </field><field name="LIST" id="vc">colors</field></block></value>
        <next>
          <block type="py_print">
            <value name="VALUE"><block type="val_var"><field name="VAR" id="vr">result</field></block></value>
            <next>
              <block type="var_set">
                <field name="VAR" id="vn">nums</field>
                <value name="VALUE">
                  <block type="py_list_literal">
                    <mutation items="3"/>
                    <value name="ITEM0"><block type="val_str"><field name="TEXT">10</field></block></value>
                    <value name="ITEM1"><block type="val_str"><field name="TEXT">20</field></block></value>
                    <value name="ITEM2"><block type="val_str"><field name="TEXT">30</field></block></value>
                  </block>
                </value>
                <next>
                  <block type="var_set">
                    <field name="VAR" id="vcl">csv_line</field>
                    <value name="VALUE"><block type="py_str_join"><field name="SEP">,</field><field name="LIST" id="vn">nums</field></block></value>
                    <next>
                      <block type="py_print">
                        <value name="VALUE"><block type="val_var"><field name="VAR" id="vcl">csv_line</field></block></value>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
