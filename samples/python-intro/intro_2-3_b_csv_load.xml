<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_rows">rows</variable>
    <variable id="var_month">month</variable>
    <variable id="var_temp">temp</variable>
  </variables>
  <block type="py_import_csv" id="b1" x="30" y="30">
    <next>
      <block type="py_csv_read_rows" id="b2">
        <field name="VAR" id="var_rows">rows</field>
        <field name="FILENAME">data.csv</field>
        <next>
          <block type="py_csv_get_col" id="b3">
            <field name="VAR" id="var_month">month</field>
            <field name="ROWS" id="var_rows">rows</field>
            <field name="COL">0</field>
            <next>
              <block type="py_csv_get_col" id="b4">
                <field name="VAR" id="var_temp">temp</field>
                <field name="ROWS" id="var_rows">rows</field>
                <field name="COL">1</field>
                <next>
                  <block type="py_print_multi" id="p1">
                    <mutation items="2"/>
                    <value name="ITEM0"><block type="val_str"><field name="TEXT">月:</field></block></value>
                    <value name="ITEM1"><block type="val_var"><field name="VAR" id="var_month">month</field></block></value>
                    <next>
                      <block type="py_print_multi" id="p2">
                        <mutation items="2"/>
                        <value name="ITEM0"><block type="val_str"><field name="TEXT">気温:</field></block></value>
                        <value name="ITEM1"><block type="val_var"><field name="VAR" id="var_temp">temp</field></block></value>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
