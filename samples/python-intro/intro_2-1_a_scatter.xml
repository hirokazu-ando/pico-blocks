<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_height">height</variable>
    <variable id="var_weight">weight</variable>
  </variables>
  <block type="py_import_plt" id="b1" x="30" y="30">
    <next>
      <block type="var_set" id="b2">
        <field name="VAR" id="var_height">height</field>
        <value name="VALUE">
          <block type="py_custom_expr" id="b3"><field name="CODE">[160, 165, 170, 175, 180]</field></block>
        </value>
        <next>
          <block type="var_set" id="b4">
            <field name="VAR" id="var_weight">weight</field>
            <value name="VALUE">
              <block type="py_custom_expr" id="b5"><field name="CODE">[55, 60, 65, 70, 75]</field></block>
            </value>
            <next>
              <block type="py_plt_scatter" id="b6">
                <value name="X"><block type="val_var" id="b7"><field name="VAR" id="var_height">height</field></block></value>
                <value name="Y"><block type="val_var" id="b8"><field name="VAR" id="var_weight">weight</field></block></value>
                <next>
                  <block type="py_plt_xlabel" id="b9">
                    <value name="TEXT"><block type="val_str" id="b10"><field name="TEXT">身長 (cm)</field></block></value>
                    <next>
                      <block type="py_plt_ylabel" id="b11">
                        <value name="TEXT"><block type="val_str" id="b12"><field name="TEXT">体重 (kg)</field></block></value>
                        <next>
                          <block type="py_plt_show" id="b13"></block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
