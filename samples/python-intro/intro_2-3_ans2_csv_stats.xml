<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_rows">rows</variable>
    <variable id="var_values">values</variable>
  </variables>
  <block type="py_import_csv" id="b1" x="30" y="30">
    <next>
      <block type="py_import_stats" id="b2">
        <next>
          <block type="py_csv_read_rows" id="b3">
            <field name="VAR" id="var_rows">rows</field>
            <field name="FILENAME">mydata.csv</field>
            <next>
              <block type="py_csv_get_col" id="b4">
                <field name="VAR" id="var_values">values</field>
                <field name="ROWS" id="var_rows">rows</field>
                <field name="COL">1</field>
                <next>
                  <block type="py_print_multi" id="p1">
                    <mutation items="2"/>
                    <value name="ITEM0"><block type="val_str"><field name="TEXT">平均:</field></block></value>
                    <value name="ITEM1">
                      <block type="py_stats_mean">
                        <value name="DATA"><block type="val_var"><field name="VAR" id="var_values">values</field></block></value>
                      </block>
                    </value>
                    <next>
                      <block type="py_print_multi" id="p2">
                        <mutation items="2"/>
                        <value name="ITEM0"><block type="val_str"><field name="TEXT">最大:</field></block></value>
                        <value name="ITEM1">
                          <block type="py_max_call">
                            <field name="LIST" id="var_values">values</field>
                          </block>
                        </value>
                        <next>
                          <block type="py_print_multi" id="p3">
                            <mutation items="2"/>
                            <value name="ITEM0"><block type="val_str"><field name="TEXT">最小:</field></block></value>
                            <value name="ITEM1">
                              <block type="py_min_call">
                                <field name="LIST" id="var_values">values</field>
                              </block>
                            </value>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
