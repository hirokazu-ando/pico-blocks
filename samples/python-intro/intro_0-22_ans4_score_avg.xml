<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vsc">scores</variable>
  </variables>
  <block type="py_file_write"><field name="FILENAME">scores.txt</field><value name="CONTENT"><block type="val_str"><field name="TEXT">85\n92\n78\n61\n95\n</field></block></value><next><block type="py_file_readlines"><field name="FILENAME">scores.txt</field><field name="VAR">lines</field><next><block type="var_set"><field name="VAR" id="vsc">scores</field><value name="VALUE"><block type="py_custom_expr"><field name="CODE">[int(line.strip()) for line in lines if line.strip()]</field></block></value><next><block type="py_print"><value name="VALUE"><block type="py_custom_expr"><field name="CODE">f"平均: {sum(scores) / len(scores):.1f}"</field></block></value></block></next></block></next></block></next></block>
</xml>
