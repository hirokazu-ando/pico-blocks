<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_hours">hours</variable>
    <variable id="var_scores">scores</variable>
  </variables>
  <block type="py_import_plt" id="b1" x="30" y="30">
    <next>
      <block type="var_set" id="b2">
        <field name="VAR" id="var_hours">hours</field>
        <value name="VALUE">
          <block type="py_custom_expr" id="b3"><field name="CODE">[1, 2, 3, 4, 5, 6, 7, 8]</field></block>
        </value>
        <next>
          <block type="var_set" id="b4">
            <field name="VAR" id="var_scores">scores</field>
            <value name="VALUE">
              <block type="py_custom_expr" id="b5"><field name="CODE">[50, 55, 62, 70, 75, 82, 88, 95]</field></block>
            </value>
            <next>
              <block type="py_plt_scatter" id="b6">
                <value name="X"><block type="val_var" id="b7"><field name="VAR" id="var_hours">hours</field></block></value>
                <value name="Y"><block type="val_var" id="b8"><field name="VAR" id="var_scores">scores</field></block></value>
                <next>
                  <block type="py_plt_title" id="b9">
                    <value name="TEXT"><block type="val_str" id="b10"><field name="TEXT">勉強時間と点数</field></block></value>
                    <next>
                      <block type="py_plt_xlabel" id="b11">
                        <value name="TEXT"><block type="val_str" id="b12"><field name="TEXT">勉強時間(時間)</field></block></value>
                        <next>
                          <block type="py_plt_ylabel" id="b13">
                            <value name="TEXT"><block type="val_str" id="b14"><field name="TEXT">点数</field></block></value>
                            <next>
                              <block type="py_plt_show" id="b15"></block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
