<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_prices">prices</variable>
    <variable id="var_total">total</variable>
    <variable id="var_name">name</variable>
  </variables>
  <block type="var_set" id="b0" x="30" y="30">
    <field name="VAR" id="var_prices">prices</field>
    <value name="VALUE">
      <block type="py_dict_literal" id="bdl">
        <mutation items="3"></mutation>
        <field name="COUNT">3</field>
        <field name="KEY0">apple</field>
        <value name="PAIR0"><block type="val_number" id="v1"><field name="NUM">120</field></block></value>
        <field name="KEY1">orange</field>
        <value name="PAIR1"><block type="val_number" id="v2"><field name="NUM">100</field></block></value>
        <field name="KEY2">grape</field>
        <value name="PAIR2"><block type="val_number" id="v3"><field name="NUM">180</field></block></value>
      </block>
    </value>
    <next>
      <block type="var_set" id="b1">
        <field name="VAR" id="var_total">total</field>
        <value name="VALUE"><block type="val_number" id="n0"><field name="NUM">0</field></block></value>
        <next>
          <block type="py_for_list" id="b2">
            <field name="VAR" id="var_name">name</field>
            <field name="LIST" id="var_prices">prices</field>
            <statement name="DO">
              <block type="var_change" id="bvc">
                <field name="VAR" id="var_total">total</field>
                <value name="AMOUNT">
                  <block type="py_dict_get" id="bdg">
                    <field name="DICT" id="var_prices">prices</field>
                    <value name="KEY"><block type="val_var" id="bvn"><field name="VAR" id="var_name">name</field></block></value>
                  </block>
                </value>
              </block>
            </statement>
            <next>
              <block type="py_print" id="b3">
                <value name="VALUE"><block type="val_var" id="bvt"><field name="VAR" id="var_total">total</field></block></value>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
