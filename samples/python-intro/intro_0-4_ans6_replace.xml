<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_text">text</variable>
  </variables>
  <block type="var_set" id="b0" x="30" y="30">
    <field name="VAR" id="var_text">text</field>
    <value name="VALUE"><block type="val_str" id="vs1"><field name="TEXT">Pythonはむずかしい。Pythonがきらいだ。</field></block></value>
    <next>
      <block type="py_custom_stmt" id="cs1">
        <field name="CODE">text = text.replace("Python", "PycoBlocks")</field>
        <next>
          <block type="py_custom_stmt" id="cs2">
            <field name="CODE">text = text.replace("むずかしい", "たのしい")</field>
            <next>
              <block type="py_custom_stmt" id="cs3">
                <field name="CODE">text = text.replace("きらい", "すき")</field>
                <next>
                  <block type="py_print" id="b1">
                    <value name="VALUE"><block type="val_var" id="bvt"><field name="VAR" id="var_text">text</field></block></value>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
