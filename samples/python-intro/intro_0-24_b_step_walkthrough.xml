<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_data">data</variable>
    <variable id="var_target">target</variable>
    <variable id="var_left">left</variable>
    <variable id="var_right">right</variable>
    <variable id="var_mid">mid</variable>
  </variables>
  <block type="var_set" x="30" y="30">
    <field name="VAR" id="var_data">data</field>
    <value name="VALUE">
      <block type="py_list_literal">
        <mutation items="5"/>
        <value name="ITEM0"><block type="val_number"><field name="NUM">1</field></block></value>
        <value name="ITEM1"><block type="val_number"><field name="NUM">3</field></block></value>
        <value name="ITEM2"><block type="val_number"><field name="NUM">5</field></block></value>
        <value name="ITEM3"><block type="val_number"><field name="NUM">7</field></block></value>
        <value name="ITEM4"><block type="val_number"><field name="NUM">9</field></block></value>
      </block>
    </value>
    <next>
      <block type="var_set">
        <field name="VAR" id="var_target">target</field>
        <value name="VALUE"><block type="val_number"><field name="NUM">7</field></block></value>
        <next>
          <block type="var_set">
            <field name="VAR" id="var_left">left</field>
            <value name="VALUE"><block type="val_number"><field name="NUM">0</field></block></value>
            <next>
              <block type="var_set">
                <field name="VAR" id="var_right">right</field>
                <value name="VALUE">
                  <block type="py_math_op">
                    <field name="OP">-</field>
                    <value name="LEFT"><block type="py_list_len"><field name="LIST" id="var_data">data</field></block></value>
                    <value name="RIGHT"><block type="val_number"><field name="NUM">1</field></block></value>
                  </block>
                </value>
                <next>
                  <block type="py_print">
                    <value name="VALUE">
                      <block type="py_fstring2_expr">
                        <field name="PRE">開始: left=</field>
                        <value name="VAR1"><block type="val_var"><field name="VAR" id="var_left">left</field></block></value>
                        <field name="MID">, right=</field>
                        <value name="VAR2"><block type="val_var"><field name="VAR" id="var_right">right</field></block></value>
                        <field name="POST"></field>
                      </block>
                    </value>
                    <next>
                      <block type="var_set">
                        <field name="VAR" id="var_mid">mid</field>
                        <value name="VALUE">
                          <block type="py_math_op">
                            <field name="OP">//</field>
                            <value name="LEFT">
                              <block type="py_math_op">
                                <field name="OP">+</field>
                                <value name="LEFT"><block type="val_var"><field name="VAR" id="var_left">left</field></block></value>
                                <value name="RIGHT"><block type="val_var"><field name="VAR" id="var_right">right</field></block></value>
                              </block>
                            </value>
                            <value name="RIGHT"><block type="val_number"><field name="NUM">2</field></block></value>
                          </block>
                        </value>
                        <next>
                          <block type="py_print">
                            <value name="VALUE">
                              <block type="py_fstring2_expr">
                                <field name="PRE">mid=</field>
                                <value name="VAR1"><block type="val_var"><field name="VAR" id="var_mid">mid</field></block></value>
                                <field name="MID">, data[mid]=</field>
                                <value name="VAR2">
                                  <block type="py_list_get">
                                    <field name="LIST" id="var_data">data</field>
                                    <value name="INDEX"><block type="val_var"><field name="VAR" id="var_mid">mid</field></block></value>
                                  </block>
                                </value>
                                <field name="POST"></field>
                              </block>
                            </value>
                            <next>
                              <block type="var_set">
                                <field name="VAR" id="var_left">left</field>
                                <value name="VALUE">
                                  <block type="py_math_op">
                                    <field name="OP">+</field>
                                    <value name="LEFT"><block type="val_var"><field name="VAR" id="var_mid">mid</field></block></value>
                                    <value name="RIGHT"><block type="val_number"><field name="NUM">1</field></block></value>
                                  </block>
                                </value>
                                <next>
                                  <block type="var_set">
                                    <field name="VAR" id="var_mid">mid</field>
                                    <value name="VALUE">
                                      <block type="py_math_op">
                                        <field name="OP">//</field>
                                        <value name="LEFT">
                                          <block type="py_math_op">
                                            <field name="OP">+</field>
                                            <value name="LEFT"><block type="val_var"><field name="VAR" id="var_left">left</field></block></value>
                                            <value name="RIGHT"><block type="val_var"><field name="VAR" id="var_right">right</field></block></value>
                                          </block>
                                        </value>
                                        <value name="RIGHT"><block type="val_number"><field name="NUM">2</field></block></value>
                                      </block>
                                    </value>
                                    <next>
                                      <block type="py_print">
                                        <value name="VALUE">
                                          <block type="py_fstring2_expr">
                                            <field name="PRE">mid=</field>
                                            <value name="VAR1"><block type="val_var"><field name="VAR" id="var_mid">mid</field></block></value>
                                            <field name="MID">, data[mid]=</field>
                                            <value name="VAR2">
                                              <block type="py_list_get">
                                                <field name="LIST" id="var_data">data</field>
                                                <value name="INDEX"><block type="val_var"><field name="VAR" id="var_mid">mid</field></block></value>
                                              </block>
                                            </value>
                                            <field name="POST"></field>
                                          </block>
                                        </value>
                                        <next>
                                          <block type="py_print">
                                            <value name="VALUE">
                                              <block type="py_fstring">
                                                <field name="PRE">見つかった！インデックス=</field>
                                                <value name="VAR"><block type="val_var"><field name="VAR" id="var_mid">mid</field></block></value>
                                                <field name="POST">（2回の比較）</field>
                                              </block>
                                            </value>
                                          </block>
                                        </next>
                                      </block>
                                    </next>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
