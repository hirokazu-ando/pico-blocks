<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables><variable id="var_x">x</variable></variables>
  <block type="py_input" id="b1" x="30" y="30">
    <field name="TYPE">int</field>
    <field name="VAR" id="var_x">x</field>
    <field name="PROMPT">整数を入力してください</field>
    <next>
      <block type="pico_if" id="b2">
        <mutation elseif="1" else="1"></mutation>
        <value name="IF0">
          <block type="cond_compare" id="b3">
            <field name="OP">&gt;</field>
            <value name="LEFT"><block type="val_var" id="b4"><field name="VAR" id="var_x">x</field></block></value>
            <value name="RIGHT"><block type="val_number" id="b5"><field name="NUM">0</field></block></value>
          </block>
        </value>
        <statement name="DO0">
          <block type="print_text" id="b6"><field name="TEXT">正の数です</field></block>
        </statement>
        <value name="IF1">
          <block type="cond_compare" id="b7">
            <field name="OP">&lt;</field>
            <value name="LEFT"><block type="val_var" id="b8"><field name="VAR" id="var_x">x</field></block></value>
            <value name="RIGHT"><block type="val_number" id="b9"><field name="NUM">0</field></block></value>
          </block>
        </value>
        <statement name="DO1">
          <block type="print_text" id="b10"><field name="TEXT">負の数です</field></block>
        </statement>
        <statement name="ELSE">
          <block type="print_text" id="b11"><field name="TEXT">ゼロです</field></block>
        </statement>
      </block>
    </next>
  </block>
</xml>
