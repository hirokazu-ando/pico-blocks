<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_i">i</variable>
    <variable id="var_squares">squares</variable>
    <variable id="var_w">w</variable>
    <variable id="var_words">words</variable>
    <variable id="var_upper">upper</variable>
  </variables>
  <block type="var_set" x="30" y="30">
    <field name="VAR" id="var_squares">squares</field>
    <value name="VALUE">
      <block type="py_list_comp">
        <field name="VAR" id="var_i">i</field>
        <value name="EXPR">
          <block type="py_math_op">
            <field name="OP">**</field>
            <value name="LEFT"><block type="val_var"><field name="VAR" id="var_i">i</field></block></value>
            <value name="RIGHT"><block type="val_number"><field name="NUM">2</field></block></value>
          </block>
        </value>
        <value name="LIST">
          <block type="py_range">
            <field name="START">1</field>
            <field name="STOP">6</field>
          </block>
        </value>
      </block>
    </value>
    <next>
      <block type="py_print">
        <value name="VALUE"><block type="val_var"><field name="VAR" id="var_squares">squares</field></block></value>
        <next>
          <block type="var_set">
            <field name="VAR" id="var_words">words</field>
            <value name="VALUE">
              <block type="py_list_literal">
                <mutation items="3"/>
                <value name="ITEM0"><block type="val_str"><field name="TEXT">apple</field></block></value>
                <value name="ITEM1"><block type="val_str"><field name="TEXT">banana</field></block></value>
                <value name="ITEM2"><block type="val_str"><field name="TEXT">cherry</field></block></value>
              </block>
            </value>
            <next>
              <block type="var_set">
                <field name="VAR" id="var_upper">upper</field>
                <value name="VALUE">
                  <block type="py_list_comp">
                    <field name="VAR" id="var_w">w</field>
                    <value name="EXPR">
                      <block type="py_str_upper">
                        <field name="VAR" id="var_w">w</field>
                      </block>
                    </value>
                    <value name="LIST"><block type="val_var"><field name="VAR" id="var_words">words</field></block></value>
                  </block>
                </value>
                <next>
                  <block type="py_print">
                    <value name="VALUE"><block type="val_var"><field name="VAR" id="var_upper">upper</field></block></value>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
