<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_nums">nums</variable>
    <variable id="var_x">x</variable>
    <variable id="var_squares">squares</variable>
  </variables>
  <block type="var_set" id="b1" x="30" y="30">
    <field name="VAR" id="var_squares">squares</field>
    <value name="VALUE">
      <block type="py_list_comp" id="b2">
        <value name="EXPR">
          <block type="py_math_op" id="b3">
            <field name="OP">**</field>
            <value name="LEFT"><block type="val_var" id="b4"><field name="VAR" id="var_x">x</field></block></value>
            <value name="RIGHT"><block type="val_number" id="b5"><field name="NUM">2</field></block></value>
          </block>
        </value>
        <value name="LIST"><block type="val_var" id="b6"><field name="VAR" id="var_nums">nums</field></block></value>
      </block>
    </value>
  </block>
</xml>
