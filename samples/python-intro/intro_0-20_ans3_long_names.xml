<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="van">animals</variable>
    <variable id="vln">long_names</variable>
    <variable id="va">a</variable>
  </variables>
  <block type="var_set" x="30" y="30">
    <field name="VAR" id="van">animals</field>
    <value name="VALUE">
      <block type="py_list_literal">
        <mutation items="6"/>
        <value name="ITEM0"><block type="val_str"><field name="TEXT">cat</field></block></value>
        <value name="ITEM1"><block type="val_str"><field name="TEXT">elephant</field></block></value>
        <value name="ITEM2"><block type="val_str"><field name="TEXT">ox</field></block></value>
        <value name="ITEM3"><block type="val_str"><field name="TEXT">giraffe</field></block></value>
        <value name="ITEM4"><block type="val_str"><field name="TEXT">ant</field></block></value>
        <value name="ITEM5"><block type="val_str"><field name="TEXT">hippopotamus</field></block></value>
      </block>
    </value>
    <next>
      <block type="var_set">
        <field name="VAR" id="vln">long_names</field>
        <value name="VALUE">
          <block type="py_list_comp_if">
            <field name="VAR" id="va">a</field>
            <value name="EXPR"><block type="val_var"><field name="VAR" id="va">a</field></block></value>
            <value name="LIST"><block type="val_var"><field name="VAR" id="van">animals</field></block></value>
            <value name="COND">
              <block type="cond_compare">
                <field name="OP">&gt;=</field>
                <value name="LEFT">
                  <block type="py_list_len">
                    <field name="LIST" id="va">a</field>
                  </block>
                </value>
                <value name="RIGHT"><block type="val_number"><field name="NUM">5</field></block></value>
              </block>
            </value>
          </block>
        </value>
        <next>
          <block type="py_print">
            <value name="VALUE"><block type="val_var"><field name="VAR" id="vln">long_names</field></block></value>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
