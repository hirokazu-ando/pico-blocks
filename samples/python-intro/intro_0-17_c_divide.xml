<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_a">a</variable>
    <variable id="var_b">b</variable>
  </variables>
  <block type="var_set" id="b1" x="30" y="30">
    <field name="VAR" id="var_a">a</field>
    <value name="VALUE">
      <block type="val_number" id="b2"><field name="NUM">10</field></block>
    </value>
    <next>
      <block type="var_set" id="b3">
        <field name="VAR" id="var_b">b</field>
        <value name="VALUE">
          <block type="val_number" id="b4"><field name="NUM">0</field></block>
        </value>
        <next>
          <block type="py_try_except" id="b5">
            <field name="ETYPE">ZeroDivisionError</field>
            <statement name="BODY">
              <block type="py_print" id="b6">
                <value name="VALUE">
                  <block type="py_math_op" id="b7">
                    <field name="OP">/</field>
                    <value name="LEFT">
                      <block type="val_var" id="b8"><field name="VAR" id="var_a">a</field></block>
                    </value>
                    <value name="RIGHT">
                      <block type="val_var" id="b9"><field name="VAR" id="var_b">b</field></block>
                    </value>
                  </block>
                </value>
              </block>
            </statement>
            <statement name="HANDLER">
              <block type="py_print" id="b10">
                <value name="VALUE">
                  <block type="val_str" id="b11"><field name="TEXT">0では割れません</field></block>
                </value>
              </block>
            </statement>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
