<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_total">total</variable>
    <variable id="var_i">i</variable>
  </variables>
  <block type="var_set" id="b0" x="30" y="30">
    <field name="VAR" id="var_total">total</field>
    <value name="VALUE"><block type="val_number" id="n0"><field name="NUM">0</field></block></value>
    <next>
      <block type="pico_for_from_to" id="b1">
        <field name="VAR" id="var_i">i</field>
        <value name="START"><block type="val_number" id="n1"><field name="NUM">1</field></block></value>
        <value name="STOP"><block type="val_number" id="n2"><field name="NUM">99</field></block></value>
        <value name="STEP"><block type="val_number" id="n3"><field name="NUM">2</field></block></value>
        <statement name="DO">
          <block type="var_change" id="bc">
            <field name="VAR" id="var_total">total</field>
            <value name="AMOUNT"><block type="val_var" id="bvi"><field name="VAR" id="var_i">i</field></block></value>
          </block>
        </statement>
        <next>
          <block type="py_print" id="b2">
            <value name="VALUE"><block type="val_var" id="bvt"><field name="VAR" id="var_total">total</field></block></value>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
